---
import AddDecibelsCalculator from '../../../components/AddDecibelsCalculator.astro';
import CalculatorPage from '../../../components/CalculatorPage.astro';
import DailyNoiseExposureCalculator from '../../../components/DailyNoiseExposureCalculator.astro';
import DistanceCalculator from '../../../components/DistanceCalculator.astro';
import SafeExposureTimePage from '../../../components/SafeExposureTimePage.astro';
import { socialImages } from '../../../data/social';
export function getStaticPaths() { return [
  { params: { locale: 'de', toolsSegment: 'werkzeuge', slug: 'expositionsdauer-rechner' }, props: { tool: 'exposure' } },
  { params: { locale: 'de', toolsSegment: 'werkzeuge', slug: 'laermexpositionsrechner' }, props: { tool: 'daily' } },
  { params: { locale: 'de', toolsSegment: 'werkzeuge', slug: 'schallpegel-entfernung' }, props: { tool: 'distance' } },
  { params: { locale: 'de', toolsSegment: 'werkzeuge', slug: 'dezibel-addieren' }, props: { tool: 'add' } },
]; }
const { tool } = Astro.props;
const page = tool === 'daily' ? { title: 'Lärmexpositionsrechner | dBcheck', description: 'Berechnen Sie den Tages-Lärmexpositionspegel L_EX,8h aus mehreren Arbeitsabschnitten nach dem EU-/Deutschland-Modell.', kicker: 'Tages-Lärmexpositionspegel', heading: 'Arbeitsabschnitte zu einem L_EX,8h-Wert zusammenfassen.', intro: 'Verwenden Sie A-bewertete Mittelungspegel und Dauern. Das Ergebnis unterstützt das Verständnis, ersetzt aber keine fachkundige Arbeitsplatzmessung.', image: socialImages.exposure } : tool === 'distance' ? { title: 'Schallpegel-Entfernungsrechner | dBcheck', description: 'Schätzen Sie die Änderung eines Schallpegels mit der Entfernung im vereinfachten Freifeld-Punktquellenmodell.', kicker: 'Schallpegel und Entfernung', heading: 'Die Entfernung ändert den Pegel – die Umgebung ändert die Regel.', intro: 'Schätzen Sie die ideale Pegeländerung zwischen zwei Entfernungen und beachten Sie Reflexionen, Hindernisse und die Richtwirkung realer Quellen.', image: socialImages.fundamentals } : { title: 'Dezibel addieren | dBcheck', description: 'Kombinieren Sie unabhängige, kompatible Schallpegel korrekt mit logarithmischer Addition.', kicker: 'Dezibel addieren', heading: 'Schallpegel werden als Energie addiert, nicht als gewöhnliche Zahlen.', intro: 'Kombinieren Sie unabhängige Pegel mit kompatiblen Messgrößen und sehen Sie ihre logarithmische Summe.', image: socialImages.fundamentals };
---
{tool === 'exposure' ? <SafeExposureTimePage locale="de" /> : <CalculatorPage title={page.title} description={page.description} kicker={page.kicker} heading={page.heading} intro={page.intro} socialImage={page.image} locale="de">
  {tool === 'daily' && <DailyNoiseExposureCalculator locale="de" />}
  {tool === 'distance' && <DistanceCalculator locale="de" />}
  {tool === 'add' && <AddDecibelsCalculator locale="de" />}
  <Fragment slot="references">
    {tool === 'daily' ? <><section><span class="kicker">Modell</span><h2>Auf acht Stunden bezogen</h2><p>Jeder Abschnitt trägt entsprechend seiner Dauer zur Schallenergie bei. Die Summe wird auf einen nominalen Achtstundentag bezogen.</p></section><section><span class="kicker">Auslösewerte</span><h2>80 und 85 dB(A)</h2><p>Die deutschen unteren und oberen Auslösewerte lösen Arbeitsschutzpflichten aus. Sie sind keine individuelle Sicherheitsgarantie.</p></section><section><span class="kicker">Offizielle Quellen</span><h2>Deutschland und EU</h2><p><a href="https://www.gesetze-im-internet.de/l_rmvibrationsarbschv/__6.html">LärmVibrationsArbSchV §6</a>, <a href="https://eur-lex.europa.eu/legal-content/EN/ALL/?uri=CELEX%3A32003L0010">Richtlinie 2003/10/EG</a>, <a href="https://laermexposition.ifa.dguv.de/">IFA-Rechner</a> und <a href="https://www.baua.de/DE/Themen/Arbeitsgestaltung/Physikalische-Faktoren/Laerm/Vorschriften">BAuA-Hinweise</a>.</p></section></> : tool === 'distance' ? <><section><span class="kicker">Modell</span><h2>Kugelförmige Ausbreitung</h2><p>Bei einer idealen Punktquelle im Freifeld sinkt der Pegel bei jeder Verdopplung der Entfernung um ungefähr 6 dB.</p></section><section><span class="kicker">Grenze</span><h2>Reale Orte sind keine Freifelder</h2><p>Wände, Boden, Gelände, Hindernisse, Quellengröße und Richtwirkung verändern die Ausbreitung.</p></section><section><span class="kicker">Verwendung</span><h2>Als Vergleich nutzen</h2><p>Das Ergebnis ist eine Modellschätzung und kein Ersatz für eine Messung am tatsächlichen Ort.</p></section></> : <><section><span class="kicker">Methode</span><h2>Umrechnen, addieren, zurückrechnen</h2><p>Jeder Pegel wird in ein lineares Energieverhältnis umgerechnet. Die Verhältnisse werden addiert und wieder in Dezibel umgerechnet.</p></section><section><span class="kicker">Schnellprüfung</span><h2>Gleiche Pegel ergeben +3 dB</h2><p>Zwei unabhängige Pegel von 80 dB ergeben ungefähr 83 dB, nicht 160 dB.</p></section><section><span class="kicker">Wichtige Grenze</span><h2>Messgrößen müssen passen</h2><p>Kombinieren Sie keine unterschiedlichen Mittelwerte, Spitzenwerte oder Bewertungen. Kohärente Signale benötigen eine andere Methode.</p></section></>}
  </Fragment>
</CalculatorPage>}
