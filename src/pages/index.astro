  </style>

  <script>
    // ================= The page that listens =================
    // Browser demo: hero-film audio → Web Audio RMS → display dB scale (0–130).
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    const listenBtn = document.getElementById('listen-btn') as HTMLButtonElement;
    const listenText = document.getElementById('listen-text')!;
    const listenIcon = document.getElementById('listen-icon')!;
    const dbValue = document.getElementById('db-value')!;
    const pill = document.getElementById('level-pill')!;
    const sweep = document.getElementById('gauge-sweep') as unknown as SVGCircleElement;
    const recDot = document.getElementById('rec-dot')!;
    const statusEl = document.getElementById('instrument-status')!;
    const statMin = document.getElementById('stat-min')!;
    const statAvg = document.getElementById('stat-avg')!;
    const statMax = document.getElementById('stat-max')!;
    const canvas = document.getElementById('spectrum') as HTMLCanvasElement;
    const cctx = canvas.getContext('2d')!;

    const ARC = 2 * Math.PI * 84;        // gauge circumference
    const ARC_SWEEP = ARC * 0.75;        // 270°
    const BANDS = 24;

    let audioCtx: AudioContext | null = null;
    let analyser: AnalyserNode | null = null;
    let timeData: Float32Array;
    let freqData: Uint8Array;
    let listening = false;
    let smoothed = 0;
    let minDb = Infinity, maxDb = -Infinity, energySum = 0, sampleCount = 0;

    const css = (v: string) => getComputedStyle(document.documentElement).getPropertyValue(v).trim();
    const COLORS = {
      quiet: css('--success'), normal: css('--primary'),
      elevated: css('--warning'), dangerous: css('--error'),
      bar: css('--primary'),
    };

    function levelFor(db: number) {
      if (db < 55) return 'quiet';
      if (db < 70) return 'normal';
      if (db < 85) return 'elevated';
      return 'dangerous';
    }

    function setupAudio() {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const src = audioCtx.createMediaElementSource(video);
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 4096;           // matches the app's FFT size
      analyser.smoothingTimeConstant = 0.6;
      src.connect(analyser);
      analyser.connect(audioCtx.destination);
      timeData = new Float32Array(analyser.fftSize);
      freqData = new Uint8Array(analyser.frequencyBinCount);
    }

    function drawSpectrum() {
      const w = canvas.width = canvas.clientWidth * devicePixelRatio;
      const h = canvas.height = 36 * devicePixelRatio;
      cctx.clearRect(0, 0, w, h);
      if (!analyser) return;
      analyser.getByteFrequencyData(freqData as any);
      const barW = w / BANDS;
      const nyquist = (audioCtx!.sampleRate) / 2;
      for (let i = 0; i < BANDS; i++) {
        // log-spaced bands, 20 Hz – 20 kHz (like the app's SpectralAnalyzer)
        const f0 = 20 * Math.pow(1000, i / BANDS);
        const f1 = 20 * Math.pow(1000, (i + 1) / BANDS);
        const b0 = Math.min(freqData.length - 1, Math.round((f0 / nyquist) * freqData.length));
        const b1 = Math.min(freqData.length, Math.max(b0 + 1, Math.round((f1 / nyquist) * freqData.length)));
        let sum = 0;
        for (let b = b0; b < b1; b++) sum += freqData[b];
        const v = sum / (b1 - b0) / 255;
        const barH = Math.max(2 * devicePixelRatio, v * h * 0.92);
        cctx.fillStyle = COLORS.bar;
        cctx.globalAlpha = 0.25 + v * 0.65;
        const r = 2 * devicePixelRatio;
        const x = i * barW + 1.5 * devicePixelRatio;
        const bw = barW - 3 * devicePixelRatio;
        cctx.beginPath();
        cctx.roundRect(x, h - barH, bw, barH, r);
        cctx.fill();
      }
      cctx.globalAlpha = 1;
    }

    function tick() {
      if (!listening || !analyser) return;
      analyser.getFloatTimeDomainData(timeData as any);
      let sq = 0;
      for (let i = 0; i < timeData.length; i++) sq += timeData[i] * timeData[i];
      const rms = Math.sqrt(sq / timeData.length);
      const dbfs = 20 * Math.log10(Math.max(rms, 1e-7));
      const db = Math.min(130, Math.max(0, dbfs + 90)); // the app's +90 offset & clamp

      // fast attack, slow decay — like a meter needle
      smoothed = db > smoothed ? smoothed * 0.6 + db * 0.4 : smoothed * 0.92 + db * 0.08;

      // session stats (avg = energy average, like the app)
      if (db > 1) {
        minDb = Math.min(minDb, db);
        maxDb = Math.max(maxDb, db);
        energySum += Math.pow(10, db / 10);
        sampleCount++;
      }

      const shown = Math.round(smoothed);
      dbValue.textContent = String(shown);
      const level = levelFor(smoothed);
      pill.textContent = level.toUpperCase();
      pill.className = 'gauge-pill ' + level;
      sweep.style.strokeDasharray = `${(smoothed / 130) * ARC_SWEEP} 999`;
      sweep.style.stroke = COLORS[level as keyof typeof COLORS] || COLORS.normal;

      if (sampleCount > 0) {
        statMin.textContent = String(Math.round(minDb));
        statMax.textContent = String(Math.round(maxDb));
        statAvg.textContent = String(Math.round(10 * Math.log10(energySum / sampleCount)));
      }

      drawSpectrum();
      requestAnimationFrame(tick);
    }

    // ---- idle spectrum: a faint synthetic "noise floor" while in standby ----
    const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let idleRaf = 0;
    function idleSpectrum(t: number) {
      if (listening) return;
      const w = canvas.width = canvas.clientWidth * devicePixelRatio;
      const h = canvas.height = 36 * devicePixelRatio;
      cctx.clearRect(0, 0, w, h);
      const barW = w / BANDS;
      for (let i = 0; i < BANDS; i++) {
        const v = 0.10
          + 0.07 * Math.sin(t / 900 + i * 0.7) * Math.sin(t / 1400 + i * 1.3)
          + 0.04 * Math.sin(t / 520 + i * 2.1);
        const barH = Math.max(2 * devicePixelRatio, Math.abs(v) * h);
        const x = i * barW + 1.5 * devicePixelRatio;
        const bw = barW - 3 * devicePixelRatio;
        cctx.fillStyle = COLORS.bar;
        cctx.globalAlpha = 0.12 + Math.abs(v) * 0.2;
        cctx.beginPath();
        cctx.roundRect(x, h - barH, bw, barH, 2 * devicePixelRatio);
        cctx.fill();
      }
      cctx.globalAlpha = 1;
      idleRaf = requestAnimationFrame(idleSpectrum);
    }
    if (!reducedMotion) idleRaf = requestAnimationFrame(idleSpectrum);

    function setListening(on: boolean) {
      listening = on;
      video.muted = !on;
      document.body.classList.toggle('is-listening', on);
      recDot.classList.toggle('live', on);
      statusEl.textContent = on ? 'Measuring' : 'Standby';
      listenText.textContent = on ? 'Mute the film' : 'Listen to the film';
      listenIcon.innerHTML = on
        ? '<path d="M6 5h4v14H6zM14 5h4v14h-4z"/>'
        : '<path d="M8 5v14l11-7z"/>';
      if (on) {
        cancelAnimationFrame(idleRaf);
      } else {
        dbValue.textContent = '--';
        pill.textContent = 'STANDBY';
        pill.className = 'gauge-pill';
        sweep.style.strokeDasharray = '0 999';
        cctx.clearRect(0, 0, canvas.width, canvas.height);
        if (!reducedMotion) idleRaf = requestAnimationFrame(idleSpectrum);
      }
    }

    listenBtn.addEventListener('click', async () => {
      try {
        if (!audioCtx) setupAudio();
        if (audioCtx!.state === 'suspended') await audioCtx!.resume();
        if (listening) { setListening(false); return; }
        await video.play().catch(() => {});
        // reset session stats for a fresh "measurement session"
        minDb = Infinity; maxDb = -Infinity; energySum = 0; sampleCount = 0;
        setListening(true);
        requestAnimationFrame(tick);
      } catch {
        // Web Audio unavailable — degrade gracefully to plain unmute
        video.muted = !video.muted;
        setListening(!video.muted);
      }
    });
  </script>
