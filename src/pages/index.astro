---
import Base from '../layouts/Base.astro';
import SoundExplorer from '../components/SoundExplorer.astro';
import ExposureCalculator from '../components/ExposureCalculator.astro';
import { getCollection } from 'astro:content';
import { commonSounds } from '../data/sounds';
import { socialImages } from '../data/social';

const [homeArticles, homeSounds] = await Promise.all([
  getCollection('articles', ({ data }) => !data.draft),
  getCollection('sounds', ({ data }) => !data.draft),
]);
const homeEntries = new Map([
  ...homeArticles.map((entry) => [`articles:${entry.id}`, entry] as const),
  ...homeSounds.map((entry) => [`sounds:${entry.id}`, entry] as const),
]);
const featuredArticles = [
  { key: 'articles:why-does-85-db-matter', featured: true },
  { key: 'articles:are-decibel-meter-apps-accurate', featured: false },
  { key: 'sounds:concert', featured: false },
  { key: 'articles:what-is-a-safe-decibel-level', featured: false },
  { key: 'articles:how-to-measure-decibels-with-android-phone', featured: false },
].map((selection) => ({ ...selection, entry: homeEntries.get(selection.key) })).filter((selection) => selection.entry);

const freeFeatures = [
  {
    n: '01',
    title: 'Live sound level meter',
    desc: 'A detailed live sound level readout with waveform, LAeq, LCpeak and session statistics. The core of dBcheck, free for everyone.',
  },
  {
    n: '02',
    title: 'Noise alerts & passive monitoring',
    desc: 'Threshold and peak alerts on your own schedule, plus user-started 5-minute passive samples of your surroundings.',
  },
  {
    n: '03',
    title: 'Weekly exposure analytics',
    desc: 'An energy-average exposure chart and hearing health status built from your last seven days of sessions.',
  },
  {
    n: '04',
    title: 'Sharing & Health Connect',
    desc: 'Shareable PNG session cards, plus optional Health Connect sync for selected dBcheck session data. Included for every user.',
  },
];

const proFeatures = [
  {
    n: '05',
    title: 'Noise dosimeter',
    desc: 'NIOSH REL and OSHA PEL models. Live dose, projected dose and an estimated remaining exposure time while you measure.',
  },
  {
    n: '06',
    title: 'Hearing test & recovery check',
    desc: 'A Hughson-Westlake style threshold test, plus a short recovery check that compares 1/4/8 kHz against your own baseline.',
  },
  {
    n: '07',
    title: 'Sleep monitor',
    desc: 'Overnight measurement with notable-event detection, showing when notable noise occurred and how loud it was.',
  },
  {
    n: '08',
    title: 'Live sound detection',
    desc: 'On-device YAMNet classification names what the meter hears (speech, music, traffic) without recording audio.',
  },
  {
    n: '09',
    title: 'Spectral analysis & octave RTA',
    desc: 'A 24-band live spectrum, spectrogram view and IEC/ANSI octave-band real-time analyzer for the frequency-curious.',
  },
  {
    n: '10',
    title: 'Pro reports & precision tools',
    desc: 'PDF reports, CSV and WAV export, unlimited history, frequency weighting A/B/C/Z/ITU-R 468 and microphone calibration.',
  },
];

const freePlan = [
  'Live dB meter, waveform & session stats',
  'Noise alerts with custom threshold & schedule',
  'Weekly exposure chart & hearing health status',
  '7-day session history',
  'Passive monitoring samples',
  'Optional Health Connect session sync',
  'PNG session share cards',
  'Dark / light theme',
];

const proPlan = [
  'Unlimited history, session names & tags',
  'Hearing test + recovery check',
  'Dosimeter with NIOSH REL / OSHA PEL',
  'Frequency weighting A/B/C/Z/ITU-R 468',
  'Microphone calibration & octave-band offsets',
  'Live spectrum, octave RTA & sound detection',
  'Sleep monitor & lock-screen live meter',
  'PDF reports, CSV & WAV export',
  'Tinnitus pitch profile & ambient sounds',
  'Home screen widget',
];
---
<Base
  title="dBcheck: sound information, tools and an Android sound meter"
  description="Explore common sound levels, free educational tools and dBcheck for Android: a personal sound awareness and hearing-result tracking app."
  socialImage={socialImages.app}
  jsonLd={[{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'dBcheck',
    url: new URL('/', Astro.site).href,
    description: 'dBcheck is an Android sound awareness app with educational sound tools.',
  }]}
>
  <!-- ============ HERO ============ -->
  <section class="hero" id="hero">
    <div class="hero-media" aria-hidden="true">
      <video id="hero-video" src="/dBcheck-hero.mp4" muted autoplay loop playsinline crossorigin="anonymous"></video>
      <div class="hero-scrim"></div>
    </div>

    <div class="hero-inner">
      <div class="hero-copy">
        <span class="kicker">An auditory observatory for Android</span>
        <h1>This page is<br/><span class="ghost-word">listening.</span></h1>
        <p class="lede">
          dBcheck turns your phone into a detailed sound awareness meter and a
          personal hearing-result tracking companion. To prove the point, this page
          measures its own soundtrack. Press <strong>Listen</strong> and watch
          the meter read the film behind these words in real time.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#get">Coming soon to Google Play</a>
          <a class="btn btn-secondary" href="#tools">Explore sound tools</a>
        </div>
      </div>

      <div class="hero-hud" id="instrument">
        <div class="hud-gauge">
          <svg class="gauge" viewBox="0 0 200 200" aria-hidden="true">
            <!-- track: 270° arc starting at 135° -->
            <circle class="gauge-track" cx="100" cy="100" r="84" />
            <circle class="gauge-sweep" id="gauge-sweep" cx="100" cy="100" r="84" />
          </svg>
          <div class="gauge-center">
            <span class="gauge-value" id="db-value">--</span>
            <span class="gauge-caption">dB</span>
          </div>
        </div>

        <div class="hud-side">
          <div class="hud-status">
            <span class="rec-dot" id="rec-dot" aria-hidden="true"></span>
            <span class="instrument-label" id="instrument-status">Standby</span>
            <span class="gauge-pill" id="level-pill">STANDBY</span>
          </div>
          <canvas id="spectrum" class="spectrum" height="36" aria-hidden="true"></canvas>
          <div class="hud-stats" aria-label="Live session statistics">
            <span class="hud-stat">min&nbsp;<b id="stat-min">–</b></span>
            <span class="hud-stat">avg&nbsp;<b id="stat-avg">–</b></span>
            <span class="hud-stat">max&nbsp;<b id="stat-max">–</b></span>
          </div>
          <button class="btn btn-primary listen-btn" id="listen-btn">
            <svg id="listen-icon" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
            <span id="listen-text">Listen to the film</span>
          </button>
          <p class="instrument-note">Source: hero film. Web Audio RMS display demo, separate from the phone measurement path.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ COMMON SOUNDS ============ -->
  <section class="sounds-preview" id="sounds">
    <div class="section-head section-head-row">
      <div>
        <span class="kicker">Common Sounds Explorer</span>
        <h2>Put everyday sound on the scale.</h2>
        <p class="section-sub">Select an example to compare its typical range and open a sourced guide when one is published.</p>
      </div>
      <a class="btn btn-tertiary" href="/sounds/">Explore all common sounds</a>
    </div>
    <SoundExplorer sounds={commonSounds} id="home-sound-explorer" compact />
  </section>

  <!-- ============ RULER DIVIDER ============ -->
  <div class="ruler" role="presentation">
    <span class="ruler-label" style="left:0">0</span>
    <span class="ruler-label" style="left:calc(65.4% - 10px); color: var(--error)">85</span>
    <span class="ruler-label" style="right:0">130 dB</span>
    <span class="ruler-danger" style="left:65.4%"></span>
  </div>

  <!-- ============ PHILOSOPHY STRIP ============ -->
  <section class="strip">
    <div class="strip-inner">
      <p class="strip-quote">
        “Sound exposure is easy to underestimate because level is only half the
        picture. Duration gives the number its meaning.”
      </p>
      <div class="strip-facts">
        <div><span class="fact-value">44.1<small> kHz</small></span><span class="fact-label">audio sampling</span></div>
        <div><span class="fact-value">0–130<small> dB</small></span><span class="fact-label">display scale</span></div>
        <div><span class="fact-value">On-device</span><span class="fact-label">audio analysis, no account required</span></div>
      </div>
    </div>
  </section>

  <!-- ============ PROBLEMS / WHY ============ -->
  <section class="why" id="why">
    <div class="section-head">
      <span class="kicker">Why dBcheck</span>
      <h2>Four questions your ears<br/>can’t answer. Your phone can.</h2>
    </div>
    <div class="why-grid">
      <article class="why-card">
        <h3>“How loud is my day, really?”</h3>
        <p>
          Traffic, open offices, cafés, the gym: everyday noise adds up, and
          ears are terrible at keeping score. dBcheck quietly counts it for
          you, so “it wasn’t that loud” becomes a number instead of a guess.
        </p>
        <details>
          <summary>The tech behind it</summary>
          <p>
            44.1 kHz audio sampling, RMS → dB conversion with LAeq energy
            averaging, 1-second persistence cadence, and weekly exposure
            analytics computed from your real sessions.
          </p>
        </details>
      </article>

      <article class="why-card">
        <h3>“How much exposure am I collecting?”</h3>
        <p>
          A single level cannot describe exposure on its own. dBcheck combines
          level and duration to help you follow how an estimated noise dose
          accumulates over time.
        </p>
        <details>
          <summary>The tech behind it</summary>
          <p>
            A real dosimeter with NIOSH REL and OSHA PEL standards: TWA, live
            dose, projected dose and estimated remaining exposure time, plus
            threshold and 85 dB peak alerts on your own schedule.
          </p>
        </details>
      </article>

      <article class="why-card">
        <h3>“What’s ruining my sleep?”</h3>
        <p>
          Nighttime sound can be difficult to place from memory. The sleep
          monitor shows when notable noise events occurred and how loud they
          were, without claiming to know what woke you.
        </p>
        <details>
          <summary>The tech behind it</summary>
          <p>
            Overnight measurement with notable-event detection, equivalent
            level and LCpeak stats, loud-period summaries and a morning
            insights view tied to each sleep session.
          </p>
        </details>
      </article>

      <article class="why-card">
        <h3>“Are my ears changing?”</h3>
        <p>
          dBcheck lets you run a personal threshold check and compare results
          with your own earlier baseline. It is designed for relative tracking,
          not a clinical hearing test or diagnosis.
        </p>
        <details>
          <summary>The tech behind it</summary>
          <p>
            A Hughson-Westlake style threshold test, plus a short recovery
            check at 1/4/8 kHz that measures shifts against your baseline.
            Personal tracking, not a medical diagnosis.
          </p>
        </details>
      </article>
    </div>
  </section>

  <!-- ============ CALCULATOR PREVIEW ============ -->
  <section class="calculator-preview" id="tools">
    <ExposureCalculator id="home-exposure-calculator" compact />
  </section>

  <!-- ============ FEATURES ============ -->
  <section class="features" id="features">
    <div class="section-head">
      <span class="kicker">Observation log</span>
      <h2>Every feature is an instrument.</h2>
      <p class="section-sub">The full list, with the technical details left in for readers who want to know exactly what’s under the hood.</p>
    </div>
    <div class="feature-group-head">
      <span class="feature-group-badge badge-free">Free</span>
      <p>In every install: no account, no trial, no time limit.</p>
    </div>
    <ol class="feature-list">
      {freeFeatures.map((f) => (
        <li class="feature-row">
          <span class="feature-n">{f.n}</span>
          <div class="feature-body">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="feature-group-head feature-group-pro">
      <span class="feature-group-badge badge-pro">Pro</span>
      <p>Unlocked with a single one-time purchase.</p>
    </div>
    <ol class="feature-list">
      {proFeatures.map((f) => (
        <li class="feature-row">
          <span class="feature-n">{f.n}</span>
          <div class="feature-body">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        </li>
      ))}
    </ol>
    <p class="privacy-note">
      Audio analysis and app data are on-device and no account is required.
      Optional Health Connect features can share supported session data when
      the user explicitly enables them. Raw audio is not uploaded for analysis.
    </p>
  </section>

  <!-- ============ PRICING ============ -->
  <section class="pricing" id="pricing">
    <div class="section-head">
      <span class="kicker">Free &amp; Pro</span>
      <h2>Start quiet. Go deep when you’re ready.</h2>
    </div>
    <div class="plans">
      <div class="plan">
        <div class="plan-head">
          <h3>Free</h3>
          <p class="plan-price"><span class="plan-amount">0</span><span class="plan-cur">€</span></p>
          <p class="plan-sub">The full meter. Forever.</p>
        </div>
        <ul>
          {freePlan.map((item) => <li>{item}</li>)}
        </ul>
        <a class="btn btn-secondary plan-btn" href="#get">Coming soon</a>
      </div>
      <div class="plan plan-pro">
        <div class="plan-head">
          <h3>Pro</h3>
          <p class="plan-price"><span class="plan-amount">12.99</span><span class="plan-cur">€</span></p>
          <p class="plan-sub">A single one-time purchase. No subscription, ever.</p>
        </div>
        <ul>
          {proPlan.map((item) => <li>{item}</li>)}
        </ul>
        <a class="btn btn-primary plan-btn" href="#get">Unlocks in-app at launch</a>
      </div>
    </div>
    <p class="web-tools-note">The web tools are free. dBcheck Pro unlocks advanced measurement and analysis on Android.</p>
  </section>

  <!-- ============ ARTICLES ============ -->
  <section class="articles-preview">
    <div class="section-head section-head-row">
      <div>
        <span class="kicker">Field notes</span>
        <h2>Articles and sound guides</h2>
        <p class="section-sub">Sourced guides for understanding sound levels, phone measurements and exposure context.</p>
      </div>
      <a class="btn btn-tertiary" href="/articles/">View all</a>
    </div>
    <div class="article-layout">
      {featuredArticles.map(({ entry, featured }) => entry && (
        <a
          class:list={['article-card', { featured }]}
          href={entry.collection === 'sounds' ? `/sounds/${entry.id}/` : `/articles/${entry.id}/`}
        >
          <span class="article-date">{entry.data.contentCluster}</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.description}</p>
          <span class="article-more">Read article <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="cta" id="get">
    <div class="cta-inner">
      <span class="kicker">Launching soon</span>
      <h2>Hear what your ears<br/>already know.</h2>
      <p>dBcheck for Android is in final tuning before release.<br/>The observatory opens soon on Google Play.</p>
      <div class="cta-actions">
        <span class="btn btn-primary btn-disabled" aria-disabled="true">Coming soon to Google Play</span>
        <a class="btn btn-secondary" href="/tools/">Explore the web tools</a>
      </div>
    </div>
  </section>

  <style>
    /* ---------- shared ---------- */
    section { max-width: var(--max-w); margin: 0 auto; padding: 0 20px; }
    h1, h2, h3 { margin: 0; }
    .section-head { margin: 96px 0 40px; display: grid; gap: 12px; }
    .section-head h2 {
      font-family: var(--font-body); font-weight: 600;
      font-size: clamp(28px, 4vw, 40px); letter-spacing: -0.01em;
    }
    .section-head-row { display: flex; align-items: end; justify-content: space-between; gap: 24px; }
    .section-head-row > div { display: grid; gap: 12px; }
    .sounds-preview, .calculator-preview { scroll-margin-top: 84px; }
    .calculator-preview { margin-top: 104px; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      min-height: 48px; padding: 0 32px;
      border-radius: 999px; border: none;
      font-family: var(--font-body); font-size: 16px; font-weight: 600;
      text-decoration: none; cursor: pointer;
      transition: opacity 160ms ease, background 160ms ease;
    }
    .btn-primary { background: linear-gradient(135deg, var(--primary), var(--secondary)); color: var(--bg); }
    .btn-primary:hover { opacity: 0.85; }
    .btn-secondary { background: var(--surface-chh); color: var(--on-surface); }
    .btn-secondary:hover { opacity: 0.92; }
    .btn-tertiary {
      background: transparent; color: var(--primary);
      font-family: var(--font-data); font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase;
      padding: 0 16px;
    }
    .btn-tertiary:hover { background: rgba(247,247,247,0.08); }
    .btn-disabled { opacity: 0.55; cursor: default; }

    /* ---------- hero ---------- */
    .hero {
      position: relative;
      max-width: none; margin: 0; padding: 0;
      min-height: calc(100svh - 68px);
      display: flex;
      overflow: hidden;
    }
    .hero-media { position: absolute; inset: 0; }
    .hero-media video {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; filter: grayscale(1) contrast(1.05);
    }
    .hero-scrim {
      position: absolute; inset: 0;
      background:
        linear-gradient(to top, var(--bg) 0%, rgba(8,8,8,0) 28%),
        linear-gradient(to bottom, rgba(8,8,8,0.5) 0%, rgba(8,8,8,0) 20%),
        linear-gradient(to right, rgba(8,8,8,0.94) 0%, rgba(8,8,8,0.8) 36%, rgba(8,8,8,0.35) 64%, rgba(8,8,8,0.15) 100%);
    }
    .hero-inner {
      position: relative;
      width: 100%; max-width: var(--max-w);
      margin: 0 auto; padding: 96px 20px 64px;
      display: flex; align-items: center;
      justify-content: space-between; gap: 48px;
    }
    .hero-copy { display: grid; gap: 24px; justify-items: start; max-width: 600px; }
    h1 {
      font-family: var(--font-data); font-weight: 700;
      font-size: clamp(44px, 6.5vw, 76px);
      line-height: 1.04; letter-spacing: -0.02em;
    }
    .ghost-word {
      color: transparent;
      -webkit-text-stroke: 1.5px var(--outline-v);
      animation: ghost-breathe 3.6s ease-in-out infinite;
    }
    @keyframes ghost-breathe {
      0%, 100% { opacity: 0.55; }
      50% { opacity: 1; }
    }
    .lede { color: var(--on-surface-v); font-size: 18px; max-width: 46ch; margin: 0; }
    .lede strong { color: var(--on-surface); }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; }

    /* ---------- hero HUD (compact meter) ---------- */
    .hero-hud {
      flex: none;
      display: flex; gap: 20px; align-items: center;
      padding: 18px 20px;
      background: rgba(8, 8, 8, 0.55);
      border: 1px solid var(--ghost);
      border-radius: 24px;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .hud-gauge {
      position: relative; flex: none;
      width: 136px; height: 136px;
      display: grid; place-items: center;
    }
    /* breathing scale while measuring — same 1 → 1.02 / 3 s motion as the app's CircularGauge */
    @keyframes gauge-breathe {
      from { scale: 1; }
      to { scale: 1.02; }
    }
    :global(body.is-listening) .hud-gauge {
      animation: gauge-breathe 3s ease-in-out infinite alternate;
    }
    .gauge { position: absolute; inset: 0; width: 100%; height: 100%; rotate: 135deg; }
    .gauge circle { fill: none; stroke-width: 8; stroke-linecap: round; }
    .gauge-track { stroke: rgba(245, 245, 245, 0.16); stroke-dasharray: 395.84 999; } /* 270° of r=84 circle */
    .gauge-sweep {
      stroke: var(--primary);
      stroke-dasharray: 0 999;
      transition: stroke-dasharray 180ms ease-out, stroke 400ms ease;
    }
    .gauge-center { position: relative; display: grid; gap: 0; justify-items: center; text-align: center; }
    .gauge-value {
      font-family: var(--font-data); font-weight: 700;
      font-size: 36px; line-height: 1; letter-spacing: -0.02em;
      font-variant-numeric: tabular-nums;
      min-width: 2ch;
    }
    .gauge-caption { font-family: var(--font-data); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--on-surface-v); }
    .hud-side { display: grid; gap: 10px; width: 236px; }
    .hud-status { display: flex; align-items: center; gap: 8px; }
    .rec-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--tertiary); flex: none;
    }
    .rec-dot.live { background: var(--error); animation: pulse 1.6s ease-in-out infinite; }
    @keyframes pulse { 50% { opacity: 0.35; } }
    .instrument-label {
      font-family: var(--font-data); font-size: 11px; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--secondary);
    }
    .gauge-pill {
      margin-left: auto;
      font-family: var(--font-data); font-size: 10px; letter-spacing: 0.1em;
      padding: 4px 12px; border-radius: 999px;
      background: var(--surface-chh); color: var(--on-surface-v);
      transition: background 300ms ease, color 300ms ease;
    }
    .gauge-pill.quiet { background: var(--success); color: #0B120B; }
    .gauge-pill.normal { background: var(--primary); color: var(--bg); }
    .gauge-pill.elevated { background: var(--warning); color: #171204; }
    .gauge-pill.dangerous { background: var(--error); color: #1A0808; }
    .spectrum { width: 100%; height: 36px; display: block; }
    .hud-stats {
      display: flex; gap: 16px;
      font-family: var(--font-data); font-size: 11px;
      letter-spacing: 0.08em; text-transform: uppercase;
      color: var(--tertiary);
    }
    .hud-stat b { color: var(--on-surface); font-weight: 600; font-variant-numeric: tabular-nums; }
    .listen-btn { width: 100%; min-height: 42px; font-size: 14px; padding: 0 20px; }
    .instrument-note {
      margin: 0; text-align: center;
      font-family: var(--font-data); font-size: 9px; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--tertiary);
    }

    /* ---------- ruler ---------- */
    .ruler {
      position: relative;
      max-width: var(--max-w); margin: 88px auto 0; height: 34px;
      margin-left: max(20px, calc((100% - var(--max-w)) / 2));
      margin-right: max(20px, calc((100% - var(--max-w)) / 2));
      background:
        repeating-linear-gradient(to right,
          var(--ghost) 0, var(--ghost) 1px, transparent 1px, transparent calc(100% / 65)),
        repeating-linear-gradient(to right,
          rgba(140,140,140,0.45) 0, rgba(140,140,140,0.45) 1px, transparent 1px, transparent calc(100% / 13));
      background-size: 100% 10px, 100% 18px;
      background-repeat: no-repeat;
      background-position: bottom left;
    }
    .ruler-label {
      position: absolute; top: -6px;
      font-family: var(--font-data); font-size: 10px; letter-spacing: 0.08em;
      color: var(--tertiary);
    }
    .ruler-danger {
      position: absolute; bottom: 0; width: 2px; height: 24px;
      background: var(--error); opacity: 0.85;
      animation: danger-blink 2.6s ease-in-out infinite;
    }
    @keyframes danger-blink {
      0%, 100% { opacity: 0.85; }
