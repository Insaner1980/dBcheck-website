      .feature-row, .feature-n { transition: none; }
    }

    /* ---------- responsive ---------- */
    @media (max-width: 1080px) {
      .hero { min-height: 0; }
      .hero-inner {
        flex-direction: column; align-items: flex-start;
        gap: 48px; padding: 80px 20px 56px;
      }
      .hero-scrim {
        background:
          linear-gradient(to top, var(--bg) 0%, rgba(8,8,8,0) 30%),
