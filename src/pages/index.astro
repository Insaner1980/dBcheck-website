      .hud-side { width: 100%; }
    }
    @media (max-width: 900px) {
      .why-grid { grid-template-columns: 1fr; }
      .strip-inner { grid-template-columns: 1fr; padding: 32px; }
      .plans { grid-template-columns: 1fr; }
      .article-layout { grid-template-columns: 1fr 1fr; }
      .article-card.featured { grid-column: 1 / -1; grid-row: auto; min-height: 340px; }
      .feature-row { grid-template-columns: 40px 1fr; }
      .feature-group-head { flex-wrap: wrap; gap: 10px; }
    }
    @media (max-width: 620px) {
      .section-head-row { align-items: start; flex-direction: column; }
      .article-layout { grid-template-columns: 1fr; }
      .article-card.featured { grid-column: auto; min-height: 300px; }
