    .article-more { font-family: var(--font-data); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--secondary); margin-top: auto; }

    /* ---------- CTA ---------- */
    .cta { margin-top: 112px; }
    .cta-inner {
      display: grid; gap: 20px; justify-items: center; text-align: center;
      border: 1px solid var(--ghost); border-radius: var(--radius-card);
