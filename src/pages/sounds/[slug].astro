---
import { getCollection } from 'astro:content';
import EditorialPage from '../../components/EditorialPage.astro';
import { findCommonSound } from '../../data/sounds';

export async function getStaticPaths() {
  const sounds = await getCollection('sounds', ({ data }) => !data.draft);
  return sounds.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const sound = findCommonSound(entry.id);
---

<EditorialPage entry={entry} kind="sound" sound={sound} />
