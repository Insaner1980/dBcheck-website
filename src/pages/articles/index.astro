---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { socialImages } from '../../data/social';

const [articles, sounds] = await Promise.all([
  getCollection('articles', ({ data }) => !data.draft),
  getCollection('sounds', ({ data }) => !data.draft),
]);

const groups = [
  {
    title: 'Decibel fundamentals',
    description: 'Definitions, SPL, weighting and the logarithmic scale.',
    entries: articles.filter((entry) => entry.data.contentCluster === 'Decibel fundamentals'),
  },
  {
    title: 'Safe exposure',
    description: 'Level, duration, dose and the differences between major guidance frameworks.',
    entries: articles.filter((entry) => entry.data.contentCluster === 'Noise exposure and hearing risk'),
  },
  {
    title: 'Smartphone measurement',
    description: 'Accuracy, calibration, repeatable procedure and professional-use boundaries.',
    entries: articles.filter((entry) => entry.data.contentCluster === 'Smartphone sound measurement'),
  },
  {
    title: 'Common sounds',
    description: 'Source-specific ranges with distance, metric and exposure context.',
    entries: sounds,
  },
].map((group) => ({
  ...group,
  entries: group.entries.sort((a, b) => a.data.title.localeCompare(b.data.title)),
}));
---

<Base title="Articles and sound guides | dBcheck" description="Sourced dBcheck guides about decibels, phone sound measurement, noise exposure and common sound levels." socialImage={socialImages.fundamentals}>
  <section class="articles-page">
    <header class="page-head">
      <h1>Articles and sound guides</h1>
      <p>Twenty evidence-aware guides organized around the concepts, measurement limits and everyday contexts needed to interpret a sound level responsibly.</p>
    </header>

    <div class="article-groups">
      {groups.map((group) => (
        <section class="article-group" aria-labelledby={`group-${group.title.toLowerCase().replaceAll(' ', '-')}`}>
          <header>
            <div>
              <span class="kicker">{group.entries.length} guides</span>
              <h2 id={`group-${group.title.toLowerCase().replaceAll(' ', '-')}`}>{group.title}</h2>
            </div>
            <p>{group.description}</p>
          </header>
          <ul>
            {group.entries.map((entry) => {
              const href = entry.collection === 'sounds' ? `/sounds/${entry.id}/` : `/articles/${entry.id}/`;
              return (
                <li>
                  <a href={href}>
                    <strong>{entry.data.title}</strong>
                    <p>{entry.data.description}</p>
                    <span>Reviewed {entry.data.lastReviewed.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>
  </section>

  <style>
    .articles-page { max-width: var(--max-w); margin: 0 auto; padding: 64px 20px 0; }
    .page-head { display: grid; gap: 16px; max-width: 820px; margin-bottom: 72px; }
    h1 { margin: 0; font: 700 var(--font-size-page-title)/1 var(--font-data); letter-spacing: -.035em; }
    .page-head p { max-width: 700px; margin: 0; color: var(--on-surface-v); font-size: 18px; }
    .article-groups { display: grid; gap: 80px; }
    .article-group > header { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: end; margin-bottom: 24px; }
    .article-group h2 { margin: 8px 0 0; font-size: 32px; }
    .article-group > header p { margin: 0; color: var(--on-surface-v); }
    .article-group ul { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; list-style: none; margin: 0; padding: 0; }
    .article-group a { display: grid; gap: 12px; height: 100%; padding: 24px; border: 1px solid var(--ghost); border-radius: var(--radius-tile); background: var(--surface); text-decoration: none; }
    .article-group a:hover { background: var(--surface-c); }
    .article-group strong { font-size: 19px; }
    .article-group p { margin: 0; color: var(--on-surface-v); font-size: 14px; }
    .article-group span { align-self: end; color: var(--tertiary); font: 10px/1.4 var(--font-data); letter-spacing: .08em; text-transform: uppercase; }
    @media (max-width: 700px) {
      .article-group > header, .article-group ul { grid-template-columns: 1fr; }
      .article-group > header { gap: 12px; }
    }
  </style>
</Base>
