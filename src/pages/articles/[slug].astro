---
import { getCollection } from 'astro:content';
import EditorialPage from '../../components/EditorialPage.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft && data.locale === 'en');
  return articles.map((entry) => ({ params: { slug: entry.data.slug }, props: { entry } }));
}

const { entry } = Astro.props;
---

<EditorialPage entry={entry} kind="article" />
