---
import Base from '../../layouts/Base.astro';
import { socialImages } from '../../data/social';
---

<Base title="Free sound tools | dBcheck" description="Free educational sound tools from dBcheck, including a functional NIOSH occupational exposure-time calculator." socialImage={socialImages.app}>
  <section class="tools-page">
    <header class="page-head">
      <span class="kicker">Tools</span>
      <h1>Useful calculations, without an account.</h1>
      <p>The web tools are free and separate from dBcheck Pro. They provide educational estimates and do not turn a phone into a certified sound level meter.</p>
    </header>

    <div class="tool-grid">
      <a class="tool-card available" href="/tools/safe-listening-time-calculator/">
        <span class="tool-status">Available now</span>
        <span class="tool-number">01</span>
        <h2>Safe Exposure Time Calculator</h2>
        <p>Estimate the time to a 100% NIOSH daily occupational dose using the 85 dBA / 8 hour / 3 dB model.</p>
        <span class="tool-link">Open calculator <span aria-hidden="true">→</span></span>
      </a>
      <article class="tool-card planned">
        <span class="tool-status">Planned</span>
        <span class="tool-number">02</span>
        <h2>Noise Dose Calculator</h2>
        <p>Combine multiple level-and-duration periods into one occupational dose estimate.</p>
      </article>
      <article class="tool-card planned">
        <span class="tool-status">Planned</span>
        <span class="tool-number">03</span>
        <h2>Concert Noise Exposure Calculator</h2>
        <p>Explore how concert level, time and breaks could contribute to an estimated dose.</p>
      </article>
    </div>
  </section>

  <style>
    .tools-page { max-width: var(--max-w); margin: 0 auto; padding: 64px 20px 0; }
    .page-head { display: grid; gap: 16px; max-width: 820px; margin-bottom: 56px; }
    h1 { margin: 0; font: 700 clamp(42px, 8vw, 76px)/1 var(--font-data); letter-spacing: -.035em; }
    .page-head p { max-width: 700px; margin: 0; color: var(--on-surface-v); font-size: 18px; }
    .tool-grid { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 18px; }
    .tool-card { position: relative; display: grid; align-content: start; gap: 16px; min-height: 360px; padding: 30px; border: 1px solid var(--ghost); border-radius: var(--radius-card); background: var(--surface); text-decoration: none; }
    .tool-card.available { background: linear-gradient(145deg, var(--surface-ch), var(--surface)); }
    .tool-card.available:hover { border-color: var(--outline-v); translate: 0 -3px; }
    .tool-status { justify-self: start; padding: 6px 10px; border-radius: 999px; background: var(--surface-chh); color: var(--secondary); font: 10px/1 var(--font-data); letter-spacing: .1em; text-transform: uppercase; }
    .available .tool-status { background: var(--on-surface); color: var(--bg); }
    .tool-number { margin-top: auto; color: var(--tertiary); font: 12px/1 var(--font-data); }
    .tool-card h2 { margin: 0; font-size: 24px; line-height: 1.15; }
    .tool-card p { margin: 0; color: var(--on-surface-v); }
    .tool-link { margin-top: auto; font-weight: 600; }
    .planned { color: var(--on-surface-v); }
    @media (prefers-reduced-motion: reduce) { .tool-card.available:hover { translate: none; } }
    @media (max-width: 900px) { .tool-grid { grid-template-columns: 1fr; } .tool-card { min-height: 280px; } }
  </style>
</Base>
