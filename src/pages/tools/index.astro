---
import Base from '../../layouts/Base.astro';
import { socialImages } from '../../data/social';
import { tools } from '../../data/tools';

const orderedTools = [...tools].sort((left, right) => left.order - right.order);
---

<Base title="Free sound tools | dBcheck" description="Use free dBcheck calculators for NIOSH exposure time, daily noise dose, distance changes and logarithmic decibel addition, or explore common sounds." socialImage={socialImages.app}>
  <section class="tools-page">
    <header class="page-head">
      <span class="kicker">Tools</span>
      <h1>Useful calculations, without an account.</h1>
      <p>The web tools are free and separate from dBcheck Pro. They provide educational estimates and do not turn a phone into a certified sound level meter.</p>
    </header>

    <ol class="tool-grid">
      {orderedTools.map((tool) => {
        const number = String(tool.order).padStart(2, '0');
        const content = (
          <>
            <span class="tool-number" aria-hidden="true">{number}</span>
            <h2>{tool.title}</h2>
            <p>{tool.description}</p>
            {tool.actionLabel && (
              <span class="tool-link">{tool.actionLabel} <span aria-hidden="true">→</span></span>
            )}
          </>
        );

        return (
          <li>
            <a class="tool-card" href={tool.href}>{content}</a>
          </li>
        );
      })}
    </ol>
  </section>

  <style>
    .tools-page { max-width: var(--max-w); margin: 0 auto; padding: 64px 20px 0; }
    .page-head { display: grid; gap: 16px; max-width: 820px; margin-bottom: 56px; }
    h1 { margin: 0; font: 700 var(--font-size-page-title)/1 var(--font-data); letter-spacing: -.035em; }
    .page-head p { max-width: 700px; margin: 0; color: var(--on-surface-v); font-size: 18px; }
    .tool-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 18px; margin: 0; padding: 0; list-style: none; }
    .tool-grid > li { display: flex; min-width: 0; grid-column: span 2; }
    .tool-grid > li:nth-child(-n + 2) { grid-column: span 3; }
    .tool-card { position: relative; display: grid; align-content: start; gap: 16px; width: 100%; min-height: 320px; padding: 30px; border: 1px solid var(--ghost); border-radius: var(--radius-card); background: linear-gradient(145deg, var(--surface-ch), var(--surface)); text-decoration: none; }
    .tool-card:hover { border-color: var(--outline-v); translate: 0 -3px; }
    .tool-number { margin-top: auto; color: var(--tertiary); font: 12px/1 var(--font-data); }
    .tool-card h2 { margin: 0; font-size: 24px; line-height: 1.15; }
    .tool-card p { margin: 0; color: var(--on-surface-v); }
    .tool-link { margin-top: auto; font-weight: 600; }
    @media (prefers-reduced-motion: reduce) { .tool-card:hover { translate: none; } }
    @media (max-width: 900px) { .tool-grid > li { grid-column: span 3; } .tool-card { min-height: 280px; } }
    @media (max-width: 620px) { .tool-grid > li { grid-column: 1 / -1; } }
  </style>
</Base>
