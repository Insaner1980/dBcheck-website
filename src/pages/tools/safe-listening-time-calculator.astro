---
import Base from '../../layouts/Base.astro';
import ExposureCalculator from '../../components/ExposureCalculator.astro';
import { socialImages } from '../../data/social';
---

<Base title="NIOSH exposure time calculator | dBcheck" description="Estimate the time to a 100% NIOSH daily occupational noise dose using the 85 dBA, 8 hour and 3 dB exchange-rate model." socialImage={socialImages.exposure}>
  <section class="calculator-page">
    <header class="page-head">
      <a href="/tools/"><span aria-hidden="true">←</span> All tools</a>
      <span class="kicker">Safe Exposure Time Calculator</span>
      <h1>Level and time share the same budget.</h1>
      <p>Move the slider to see how a constant A-weighted level changes the NIOSH daily occupational exposure estimate.</p>
    </header>

    <ExposureCalculator id="full-exposure-calculator" showLink={false} />

    <div class="reference-grid">
      <section>
        <span class="kicker">How it works</span>
        <h2>The 3 dB exchange rate</h2>
        <p>The model starts at 85 dBA for 8 hours. Every 3 dB increase doubles sound energy and halves the estimated duration: 88 dBA for 4 hours, 91 dBA for 2 hours and 94 dBA for 1 hour.</p>
      </section>
      <section>
        <span class="kicker">Important limits</span>
        <h2>An occupational estimate, not a promise</h2>
        <p>NIOSH REL is designed for workplace exposure. Individual susceptibility varies, and impulse sounds, changing levels and non-work listening need more context than this single-level estimate provides.</p>
      </section>
      <section>
        <span class="kicker">Measurement context</span>
        <h2>Your input matters</h2>
        <p>Phone measurements depend on the microphone, processing and calibration. dBcheck is not a certified Class 1 or Class 2 instrument, so do not use an unverified reading for regulatory decisions.</p>
      </section>
    </div>
  </section>

  <style>
    .calculator-page { max-width: var(--max-w); margin: 0 auto; padding: 56px 20px 0; }
    .page-head { display: grid; gap: 16px; max-width: 820px; margin-bottom: 48px; }
    .page-head > a { justify-self: start; margin-bottom: 24px; color: var(--secondary); font-size: 13px; text-underline-offset: 4px; }
    h1 { margin: 0; font: 700 clamp(42px, 8vw, 76px)/1 var(--font-data); letter-spacing: -.035em; }
    .page-head p { max-width: 700px; margin: 0; color: var(--on-surface-v); font-size: 18px; }
    .reference-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-top: 36px; }
    .reference-grid section { padding: 28px; border: 1px solid var(--ghost); border-radius: var(--radius-card); background: var(--surface); }
    .reference-grid h2 { margin: 10px 0; font-size: 21px; }
    .reference-grid p { margin: 0; color: var(--on-surface-v); font-size: 14px; }
    @media (max-width: 850px) { .reference-grid { grid-template-columns: 1fr; } }
  </style>
</Base>
