---
import NumberField from './NumberField.astro';
interface Props { locale?: 'en' | 'de' }
const { locale = 'en' } = Astro.props; const de = locale === 'de';
---
<section class="tool-calculator" aria-labelledby="daily-exposure-title" data-daily-exposure-calculator data-locale={locale} data-invalid-message={de ? 'Geben Sie für jeden Abschnitt einen Pegel und eine positive Dauer ein.' : 'Enter a level and positive duration for every period.'} data-duration-message={de ? 'Die Gesamtdauer darf 24 Stunden nicht überschreiten.' : 'The combined duration cannot exceed 24 hours.'} data-row-label={de ? 'Arbeitsabschnitt' : 'Work period'} data-category-below={de ? 'Der untere Auslösewert von 80 dB(A) wird nicht erreicht.' : 'The lower action value of 80 dB(A) is not reached.'} data-category-lower={de ? 'Der untere Auslösewert von 80 dB(A) wird erreicht.' : 'The lower action value of 80 dB(A) is reached.'} data-category-upper={de ? 'Der obere Auslösewert von 85 dB(A) wird erreicht.' : 'The upper action value of 85 dB(A) is reached.'} data-hours-label={de ? 'Gesamtdauer' : 'Combined duration'}>
  <form class="calculator-form" data-daily-exposure-form>
    <h2 id="daily-exposure-title">{de ? 'Arbeitsabschnitte' : 'Work periods'}</h2>
    <p class="form-intro">{de ? 'Fügen Sie bis zu zwölf Abschnitte mit annähernd konstantem A-bewertetem Mittelungspegel und ihrer Dauer hinzu.' : 'Add up to twelve periods with an approximately constant A-weighted equivalent level and duration.'}</p>
    <div class="entry-list" data-daily-period-list>
      <fieldset class="entry-row" data-daily-period><legend>{de ? 'Arbeitsabschnitt 1' : 'Work period 1'}</legend><NumberField locale={locale} id="daily-level-1" label={de ? 'L_Aeq (dB(A))' : 'L_Aeq (dB(A))'} inputAttributes={{ 'data-daily-level':'', type:'number', min:'0', max:'200', step:'0.1', value:'85', inputmode:'decimal', required:true }} /><NumberField locale={locale} id="daily-duration-1" label={de ? 'Dauer' : 'Duration'} inputAttributes={{ 'data-daily-duration':'', type:'number', min:'0.01', max:'24', step:'0.01', value:'8', inputmode:'decimal', required:true }} /><label class="field"><span>{de ? 'Einheit' : 'Unit'}</span><select data-daily-unit><option value="hours">{de ? 'Stunden' : 'hours'}</option><option value="minutes">{de ? 'Minuten' : 'minutes'}</option></select></label><button class="row-button" data-remove-daily type="button">{de ? 'Entfernen' : 'Remove'}</button></fieldset>
    </div>
    <button class="add-button" data-add-daily type="button">{de ? 'Abschnitt hinzufügen' : 'Add period'}</button>
  </form>
  <aside class="result-panel" aria-labelledby="daily-result-title"><h2 id="daily-result-title">{de ? 'Tages-Lärmexpositionspegel' : 'Daily noise exposure level'}</h2><div class="calculator-result" role="status" aria-live="polite"><span>L_EX,8h</span><strong data-daily-output>{de ? '85,0 dB(A)' : '85.0 dB(A)'}</strong><p class="result-detail" data-daily-category>{de ? 'Der obere Auslösewert von 85 dB(A) wird erreicht.' : 'The upper action value of 85 dB(A) is reached.'}</p><p class="result-detail" data-daily-hours>{de ? 'Gesamtdauer: 8,0 h' : 'Combined duration: 8.0 h'}</p></div><p class="model-note">L_EX,8h = 10 log₁₀(Σ[(Tᵢ / 8 h) × 10^(L_Aeq,ᵢ / 10)])</p><p class="result-note">{de ? 'Der EU-Expositionsgrenzwert von 87 dB(A) wird unter Berücksichtigung der tatsächlichen Gehörschutzwirkung beurteilt. Dieser Rechner zieht keine nominelle Dämmung ab und behandelt keine C-bewerteten Spitzenwerte.' : 'The EU exposure limit value of 87 dB(A) is assessed after accounting for actual hearing-protector attenuation. This calculator does not subtract nominal attenuation or evaluate C-weighted peak values.'}</p><noscript><p class="noscript-note">{de ? 'Für die Live-Berechnung ist JavaScript erforderlich. 85 dB(A) über 8 Stunden ergeben 85,0 dB(A) L_EX,8h.' : 'JavaScript is required for live calculation. 85 dB(A) for 8 hours gives 85.0 dB(A) L_EX,8h.'}</p></noscript></aside>
  <template data-daily-template><fieldset class="entry-row" data-daily-period><legend>{de ? 'Arbeitsabschnitt' : 'Work period'}</legend><NumberField locale={locale} id="daily-level-template" label="L_Aeq (dB(A))" inputAttributes={{ 'data-daily-level':'', type:'number', min:'0', max:'200', step:'0.1', value:'85', inputmode:'decimal', required:true }} /><NumberField locale={locale} id="daily-duration-template" label={de ? 'Dauer' : 'Duration'} inputAttributes={{ 'data-daily-duration':'', type:'number', min:'0.01', max:'24', step:'0.01', value:'1', inputmode:'decimal', required:true }} /><label class="field"><span>{de ? 'Einheit' : 'Unit'}</span><select data-daily-unit><option value="hours">{de ? 'Stunden' : 'hours'}</option><option value="minutes">{de ? 'Minuten' : 'minutes'}</option></select></label><button class="row-button" data-remove-daily type="button">{de ? 'Entfernen' : 'Remove'}</button></fieldset></template>
</section>
