---
interface Props {
  id: string;
  label: string;
  inputAttributes: Record<string, string | number | boolean>;
}

const { id, label, inputAttributes } = Astro.props;
---

<div class="field" data-number-stepper>
  <label data-number-label for={id}>{label}</label>
  <div class="number-control">
    <input id={id} {...inputAttributes} />
    <span class="number-stepper">
      <button type="button" data-number-step="up" aria-label={`Increase ${label}`}>
        <svg aria-hidden="true" viewBox="0 0 12 8"><path d="m2 6 4-4 4 4" /></svg>
      </button>
      <button type="button" data-number-step="down" aria-label={`Decrease ${label}`}>
        <svg aria-hidden="true" viewBox="0 0 12 8"><path d="m2 2 4 4 4-4" /></svg>
      </button>
    </span>
  </div>
</div>
