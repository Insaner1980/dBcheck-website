---
import Base from '../layouts/Base.astro';
import { socialImages } from '../data/social';
import { getTools } from '../data/tools';
import type { Locale } from '../i18n/config';
interface Props { locale: Locale }
const { locale } = Astro.props; const de = locale === 'de'; const orderedTools = [...getTools(locale)].sort((a,b) => a.order-b.order);
---
<Base title={de ? 'Kostenlose Schall-Rechner und Werkzeuge | dBcheck' : 'Free sound tools | dBcheck'} description={de ? 'Kostenlose Rechner für Expositionsdauer, Tages-Lärmexposition, Entfernung und logarithmische Dezibeladdition sowie der Alltagsgeräusche-Explorer.' : 'Use free dBcheck calculators for NIOSH exposure time, daily noise dose, distance changes and logarithmic decibel addition, or explore common sounds.'} socialImage={socialImages.app} locale={locale}>
  <section class="tools-page"><header class="page-head"><span class="kicker">{de ? 'Werkzeuge' : 'Tools'}</span><h1>{de ? 'Nützliche Berechnungen ohne Konto.' : 'Useful calculations, without an account.'}</h1><p>{de ? 'Die Web-Werkzeuge sind kostenlos. Sie liefern verständliche Näherungen und machen ein Smartphone nicht zu einem zertifizierten Schallpegelmesser.' : 'The web tools are free and separate from dBcheck Pro. They provide educational estimates and do not turn a phone into a certified sound level meter.'}</p></header>
    <ol class="tool-grid">{orderedTools.map((tool) => <li><a class="tool-card" href={tool.href}><span class="tool-number" aria-hidden="true">{String(tool.order).padStart(2,'0')}</span><h2>{tool.title}</h2><p>{tool.description}</p><span class="tool-link">{tool.actionLabel} <span aria-hidden="true">→</span></span></a></li>)}</ol>
  </section>
  <style>
    .tools-page{max-width:var(--max-w);margin:0 auto;padding:64px 20px 0}.page-head{display:grid;gap:16px;max-width:820px;margin-bottom:56px}h1{margin:0;font:700 var(--font-size-page-title)/1 var(--font-data);letter-spacing:-.035em}.page-head p{max-width:700px;margin:0;color:var(--on-surface-v);font-size:18px}.tool-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:18px;margin:0;padding:0;list-style:none}.tool-grid>li{display:flex;min-width:0;grid-column:span 2}.tool-grid>li:nth-child(-n+2){grid-column:span 3}.tool-card{position:relative;display:grid;align-content:start;gap:16px;width:100%;min-height:320px;padding:30px;border:1px solid var(--ghost);border-radius:var(--radius-card);background:linear-gradient(145deg,var(--surface-ch),var(--surface));text-decoration:none}.tool-card:hover{border-color:var(--outline-v);translate:0 -3px}.tool-number{margin-top:auto;color:var(--tertiary);font:12px/1 var(--font-data)}.tool-card h2{margin:0;font-size:24px;line-height:1.15}.tool-card p{margin:0;color:var(--on-surface-v)}.tool-link{margin-top:auto;font-weight:600}@media(prefers-reduced-motion:reduce){.tool-card:hover{translate:none}}@media(max-width:900px){.tool-grid>li{grid-column:span 3}.tool-card{min-height:280px}}@media(max-width:620px){.tool-grid>li,.tool-grid>li:nth-child(-n+2){grid-column:1/-1}}
  </style>
</Base>
