---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import 'katex/dist/katex.min.css';
import Base from '../layouts/Base.astro';
import type { CommonSound } from '../data/sounds';
import { socialImageForEditorial } from '../data/social';
import { localeTags } from '../i18n/config';
import { routeForContent } from '../i18n/routes';

type EditorialEntry = CollectionEntry<'articles'> | CollectionEntry<'sounds'>;

interface Props {
  entry: EditorialEntry;
  kind: 'article' | 'sound';
  sound?: CommonSound;
}

const { entry, kind, sound } = Astro.props;
const locale = entry.data.locale;
const isGerman = locale === 'de';
const { Content } = await render(entry);
const [articles, sounds] = await Promise.all([
  getCollection('articles', ({ data }) => !data.draft && data.locale === locale),
  getCollection('sounds', ({ data }) => !data.draft && data.locale === locale),
]);

const routeFor = (item: EditorialEntry) => routeForContent(item.data.locale, item.collection, item.data.slug);
const allEntries = [...articles, ...sounds];
const entriesByRoute = new Map(allEntries.map((item) => [routeFor(item), item]));
const linkedRoutes = Array.from(entry.body?.matchAll(/\]\((\/(?:de\/)?(?:articles|sounds)\/[^)#?]+\/)\)/g) ?? [])
  .map((match) => match[1]);
const related = Array.from(new Set(linkedRoutes))
  .map((route) => ({ route, entry: entriesByRoute.get(route) }))
  .filter((item): item is { route: string; entry: EditorialEntry } => Boolean(item.entry) && item.entry.id !== entry.id)
  .slice(0, 4);

const pagePath = routeFor(entry);
const pageUrl = new URL(pagePath, Astro.site).href;
const indexPath = routeForContent(locale, kind === 'sound' ? 'sounds' : 'articles', '').replace(/\/\/$/, '/');
const indexLabel = kind === 'sound' ? (isGerman ? 'Alltagsgeräusche' : 'Common sounds') : (isGerman ? 'Artikel' : 'Articles');
const reviewed = entry.data.lastReviewed.toLocaleDateString(localeTags[locale], {
  year: 'numeric', month: 'long', day: 'numeric',
});
const published = entry.data.publishedAt.toLocaleDateString(localeTags[locale], {
  year: 'numeric', month: 'long', day: 'numeric',
});
const publishedIso = entry.data.publishedAt.toISOString();
const modifiedIso = new Date(Math.max(
  entry.data.publishedAt.getTime(),
  entry.data.lastReviewed.getTime(),
)).toISOString();
const socialImage = socialImageForEditorial(kind, entry.data.clusterKey);
const socialImageUrl = new URL(socialImage.src, Astro.site).href;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  image: socialImageUrl,
  author: {
    '@type': 'Organization',
    name: 'dBcheck',
    url: new URL('/', Astro.site).href,
  },
  datePublished: publishedIso,
  dateModified: modifiedIso,
  mainEntityOfPage: pageUrl,
  inLanguage: localeTags[locale],
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: isGerman ? 'Startseite' : 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: indexLabel, item: new URL(indexPath, Astro.site).href },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: pageUrl },
  ],
};

const cta = isGerman ? (kind === 'sound'
  ? { kicker: 'Vergleichen', title: 'Ordnen Sie den Bereich immer in seinen Messkontext ein.', copy: 'Vergleichen Sie typische Bereiche, ohne einen einzelnen Wert als allgemeingültig zu behandeln.', label: 'Weitere Alltagsgeräusche vergleichen', href: '/de/alltagsgeraeusche/' }
  : entry.data.clusterKey === 'exposure'
    ? { kicker: 'Berechnen', title: 'Vergleichen Sie Pegel und Dauer mit einem benannten Modell.', copy: 'Der L_EX,8h-Rechner liefert eine arbeitsbezogene Orientierung, keine persönliche Sicherheitsgarantie.', label: 'Lärmexpositionspegel berechnen', href: '/de/werkzeuge/laermexpositionsrechner/' }
    : entry.data.clusterKey === 'smartphone'
      ? { kicker: 'Messen', title: 'Gestalten Sie Smartphone-Messungen wiederholbar.', copy: 'Beachten Sie Hardware, Verarbeitung, Position, Dauer und Kalibrierung.', label: 'Messanleitung lesen', href: '/de/artikel/dezibel-messen-mit-android-handy/' }
      : { kicker: 'Anwenden', title: 'Setzen Sie das Konzept in einen Alltagskontext.', copy: 'Vergleichen Sie typische Bereiche und beachten Sie Abstand, Umgebung und Messmethode.', label: 'Alltagsgeräusche entdecken', href: '/de/alltagsgeraeusche/' })
  : kind === 'sound'
  ? {
      kicker: 'Compare',
      title: 'Keep the range beside its measurement context.',
      copy: 'Use the Common Sounds Explorer to compare sourced ranges without treating one value as universal.',
      label: 'Compare more common sounds',
      href: '/sounds/',
    }
  : entry.data.contentCluster === 'Noise exposure and hearing risk'
    ? {
        kicker: 'Calculate',
        title: 'Compare level and time under a named model.',
        copy: 'The NIOSH calculator provides an occupational reference time, not an individual safety guarantee.',
        label: 'Open the Safe Exposure Time Calculator',
        href: '/tools/safe-listening-time-calculator/',
      }
    : entry.data.contentCluster === 'Smartphone sound measurement'
      ? {
          kicker: 'Measure',
          title: 'Build a repeatable phone measurement.',
          copy: 'Keep hardware, processing, position, duration and calibration visible when comparing results.',
          label: 'See dBcheck measurement features',
          href: '/#features',
        }
      : {
          kicker: 'Apply',
          title: 'Put the concept into everyday context.',
          copy: 'Compare sourced sound ranges while keeping distance, environment and measurement method visible.',
          label: 'Explore common sound levels',
          href: '/sounds/',
        };
---

<Base
  title={`${entry.data.title} | dBcheck`}
  description={entry.data.description}
  ogType="article"
  socialImage={socialImage}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
  locale={locale}
>
  <article class="editorial">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">{isGerman ? 'Startseite' : 'Home'}</a></li>
        <li><a href={indexPath}>{indexLabel}</a></li>
        <li aria-current="page">{entry.data.title}</li>
      </ol>
    </nav>

    <header class="editorial-head">
      <div class="eyebrow-row">
        <span class="kicker">{entry.data.contentCluster}</span>
        <span>
          {isGerman ? 'Von dBcheck · Veröffentlicht' : 'By dBcheck · Published'} {published}
          {' · '}{isGerman ? 'Geprüft' : 'Reviewed'} {reviewed}
        </span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
    </header>

    {kind === 'sound' && sound && (
      <section class="sound-summary" aria-label={isGerman ? `Messübersicht für ${sound.name}` : `${sound.name} measurement summary`}>
        <div><span>{isGerman ? 'Typischer Bereich' : 'Typical range'}</span><strong>{sound.typicalMinDb}–{sound.typicalMaxDb} dBA</strong></div>
        <div><span>{isGerman ? 'Messabstand' : 'Measurement distance'}</span><strong>{sound.measurementDistance}</strong></div>
        <div><span>{isGerman ? 'Geräuschtyp' : 'Sound type'}</span><strong>{sound.soundType}</strong></div>
        <div><span>{isGerman ? 'Expositionskontext' : 'Exposure context'}</span><strong>{sound.exposureNote}</strong></div>
      </section>
    )}

    <div class="prose">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="related" aria-labelledby="related-title">
        <span class="kicker">{isGerman ? 'Weiterlesen' : 'Continue reading'}</span>
        <h2 id="related-title">{isGerman ? 'Verwandte Artikel' : 'Related articles'}</h2>
        <ul>
          {related.map((item) => (
            <li><a href={item.route}><strong>{item.entry.data.title}</strong><span>{item.entry.data.description}</span></a></li>
          ))}
        </ul>
      </section>
    )}

    <aside class="article-cta">
      <span class="kicker">{cta.kicker}</span>
      <h2>{cta.title}</h2>
      <p>{cta.copy}</p>
      <a href={cta.href}>{cta.label} <span aria-hidden="true">→</span></a>
    </aside>
  </article>

  <style>
    .editorial { max-width: 820px; margin: 0 auto; padding: 48px 20px 0; }
    .breadcrumbs { margin-bottom: 48px; color: var(--secondary); font-size: 13px; }
    .breadcrumbs ol { display: flex; flex-wrap: wrap; gap: 8px; list-style: none; margin: 0; padding: 0; }
    .breadcrumbs li:not(:last-child)::after { content: '/'; margin-left: 8px; color: var(--tertiary); }
    .breadcrumbs a { text-underline-offset: 4px; }
    .editorial-head { display: grid; gap: 18px; margin-bottom: 40px; }
    .eyebrow-row { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 12px; color: var(--tertiary); font: 11px/1.4 var(--font-data); text-transform: uppercase; letter-spacing: .08em; }
    h1 { margin: 0; font: 700 clamp(36px, 7vw, 64px)/1.02 var(--font-data); letter-spacing: -.035em; }
    .lede { max-width: 720px; margin: 0; color: var(--on-surface-v); font-size: 19px; line-height: 1.6; }
    .sound-summary { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; overflow: hidden; margin: 0 0 48px; border: 1px solid var(--ghost); border-radius: var(--radius-card); background: var(--ghost); }
    .sound-summary div { display: grid; gap: 8px; align-content: start; padding: 22px; background: var(--surface); }
    .sound-summary span { color: var(--tertiary); font: 10px/1.2 var(--font-data); letter-spacing: .1em; text-transform: uppercase; }
    .sound-summary strong { color: var(--on-surface); font-size: 15px; line-height: 1.5; }
    .prose { color: var(--on-surface-v); font-size: 17px; line-height: 1.75; }
    .prose :global(h2) { color: var(--on-surface); font-size: 28px; line-height: 1.25; margin: 52px 0 14px; }
    .prose :global(h3) { color: var(--on-surface); font-size: 21px; line-height: 1.35; margin: 36px 0 10px; }
    .prose :global(p), .prose :global(ul), .prose :global(ol) { margin-block: 0 20px; }
    .prose :global(li + li) { margin-top: 7px; }
    .prose :global(strong) { color: var(--on-surface); }
    .prose :global(a) { color: var(--on-surface); text-underline-offset: 4px; overflow-wrap: anywhere; }
    .prose :global(blockquote) { margin: 28px 0; padding: 4px 0 4px 20px; border-left: 2px solid var(--outline-v); color: var(--on-surface); }
    .prose :global(code) { font-family: var(--font-data); font-size: .9em; background: var(--surface-ch); border-radius: 6px; padding: 2px 6px; }
    .prose :global(hr) { border: 0; border-top: 1px solid var(--ghost); margin: 44px 0; }
    .prose :global(table) { display: block; width: 100%; max-width: 100%; overflow-x: auto; border-collapse: collapse; margin: 24px 0 32px; }
    .prose :global(th), .prose :global(td) { min-width: 130px; border: 1px solid var(--ghost); padding: 10px 12px; text-align: left; vertical-align: top; }
    .prose :global(th) { color: var(--on-surface); background: var(--surface); }
    .prose :global(.katex-display) { max-width: 100%; overflow-x: auto; overflow-y: hidden; padding: 8px 0; }
    .prose :global(h2#sources + ol) { padding: 24px 24px 24px 44px; border: 1px solid var(--ghost); border-radius: var(--radius-tile); background: var(--surface); font-size: 14px; }
    .related { margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--ghost); }
    .related h2 { margin: 8px 0 24px; font-size: 28px; }
    .related ul { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; list-style: none; margin: 0; padding: 0; }
    .related a { display: grid; gap: 8px; height: 100%; padding: 20px; border: 1px solid var(--ghost); border-radius: var(--radius-tile); background: var(--surface); text-decoration: none; }
    .related a:hover { background: var(--surface-c); }
    .related span { color: var(--secondary); font-size: 13px; line-height: 1.5; }
    .article-cta { margin-top: 24px; padding: 32px; border: 1px solid var(--ghost); border-radius: var(--radius-card); background: var(--surface-c); }
    .article-cta h2 { margin: 8px 0 10px; font-size: 28px; }
    .article-cta p { margin: 0; color: var(--on-surface-v); }
    .article-cta a { display: inline-block; margin-top: 20px; font-weight: 700; text-underline-offset: 5px; }
    @media (max-width: 620px) {
      .editorial { padding-top: 32px; }
      .breadcrumbs { margin-bottom: 36px; }
      .sound-summary, .related ul { grid-template-columns: 1fr; }
      .article-cta { padding: 24px; }
    }
  </style>
</Base>
