---
import type { CommonSound } from '../data/sounds';

interface Props {
  sounds: CommonSound[];
  id?: string;
  compact?: boolean;
}

const { sounds, id = 'sound-explorer', compact = false } = Astro.props;
const initial = sounds[0];
---

<div id={id} class:list={['sound-explorer', { compact }]} data-sound-explorer>
  <div class="sound-scale" aria-label="Common sound examples on a 0 to 130 decibel display scale">
    <div class="scale-track" aria-hidden="true">
      <span>0</span><span>40</span><span>70</span><span>85</span><span>100</span><span>130 dB</span>
    </div>
    <div class="sound-markers">
      {sounds.map((sound, index) => (
        <button
          type="button"
          class:list={['sound-marker', sound.riskLevel, { active: index === 0 }]}
          style={`--position:${Math.min((sound.typicalMinDb + sound.typicalMaxDb) / 2, 130) / 130 * 100}%`}
          aria-pressed={index === 0 ? 'true' : 'false'}
          aria-controls={`${id}-detail`}
          data-name={sound.name}
          data-range={`${sound.typicalMinDb}–${sound.typicalMaxDb} dB`}
          data-description={sound.shortDescription}
          data-note={sound.exposureNote}
          data-route={sound.articleRoute ?? ''}
          data-lane={sound.markerLane}
        >
          <span class="marker-dot" aria-hidden="true"></span>
          <span>{sound.name}</span>
        </button>
      ))}
    </div>
  </div>

  <article class="sound-detail" id={`${id}-detail`} aria-live="polite">
    <div>
      <span class="detail-category">Typical example</span>
      <h3 data-sound-name>{initial.name}</h3>
      <p data-sound-description>{initial.shortDescription}</p>
      <p class="exposure-note" data-sound-note>{initial.exposureNote}</p>
    </div>
    <div class="detail-reading">
      <strong data-sound-range>{initial.typicalMinDb}–{initial.typicalMaxDb} dB</strong>
      <a data-sound-route href={initial.articleRoute ?? '/sounds/'} hidden={!initial.articleRoute}>Read sound guide <span aria-hidden="true">→</span></a>
    </div>
  </article>

  <div class="mobile-sound-view">
    <div class="mobile-scale-key" aria-hidden="true"><span>0</span><span>130 dB</span></div>
    <ul class="mobile-sound-list" aria-label="Common sound examples by typical decibel range">
      {sounds.map((sound, index) => (
        <li>
          <details name={`${id}-mobile-sounds`} open={index === 0}>
            <summary>
              <span class:list={['mobile-risk-dot', sound.riskLevel]} aria-hidden="true"></span>
              <span class="mobile-sound-name">{sound.name}</span>
              <strong>{sound.typicalMinDb}–{sound.typicalMaxDb} dB</strong>
              <span class="mobile-disclosure" aria-hidden="true"></span>
              <span class="mobile-range-track" aria-hidden="true">
                <span
                  class:list={['mobile-range-fill', sound.riskLevel]}
                  style={`--range-start:${sound.typicalMinDb / 130 * 100}%;--range-end:${Math.min(sound.typicalMaxDb, 130) / 130 * 100}%`}
                ></span>
              </span>
            </summary>
            <div class="mobile-sound-detail">
              <p>{sound.shortDescription}</p>
              <p class="mobile-exposure-note">{sound.exposureNote}</p>
              {sound.articleRoute && <a href={sound.articleRoute}>Read sound guide <span aria-hidden="true">→</span></a>}
            </div>
          </details>
        </li>
      ))}
    </ul>
  </div>

  <p class="sound-disclaimer">Typical ranges vary with distance, environment, source and measurement method.</p>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-sound-explorer]').forEach((explorer) => {
    const markers = Array.from(explorer.querySelectorAll<HTMLButtonElement>('.sound-marker'));
    const name = explorer.querySelector<HTMLElement>('[data-sound-name]');
    const range = explorer.querySelector<HTMLElement>('[data-sound-range]');
    const description = explorer.querySelector<HTMLElement>('[data-sound-description]');
    const note = explorer.querySelector<HTMLElement>('[data-sound-note]');
    const route = explorer.querySelector<HTMLAnchorElement>('[data-sound-route]');

    const select = (marker: HTMLButtonElement) => {
      markers.forEach((item) => {
        const active = item === marker;
        item.classList.toggle('active', active);
        item.setAttribute('aria-pressed', String(active));
      });
      if (name) name.textContent = marker.dataset.name ?? '';
      if (range) range.textContent = marker.dataset.range ?? '';
      if (description) description.textContent = marker.dataset.description ?? '';
      if (note) note.textContent = marker.dataset.note ?? '';
      if (route) {
        const target = marker.dataset.route ?? '';
        route.hidden = !target;
        route.href = target || '/sounds/';
      }
    };

    markers.forEach((marker) => {
      marker.addEventListener('click', () => select(marker));
      marker.addEventListener('pointerenter', (event) => {
        if ((event as PointerEvent).pointerType !== 'touch') select(marker);
      });
    });
  });
</script>

<style>
  .sound-explorer { display: grid; gap: 20px; }
  .sound-scale {
    position: relative; min-height: 250px; overflow-x: auto; overflow-y: hidden;
    border: 1px solid var(--ghost); border-radius: var(--radius-card);
    background: linear-gradient(180deg, rgba(255,255,255,.025), transparent), var(--surface);
    padding: 28px 24px 22px;
  }
  .scale-track {
    position: absolute; left: 24px; right: 24px; bottom: 30px;
    display: flex; justify-content: space-between;
    border-top: 1px solid var(--outline-v); padding-top: 9px;
    color: var(--tertiary); font: 10px/1 var(--font-data); letter-spacing: .08em;
  }
  .scale-track::after {
    content: ''; position: absolute; left: calc(85 / 130 * 100%); top: -1px; bottom: 17px;
    border-left: 1px solid color-mix(in srgb, var(--warning) 55%, transparent);
  }
  .sound-markers { position: relative; min-width: 720px; height: 174px; margin: 0 8px; }
  .sound-marker {
    position: absolute; left: var(--position); bottom: 22px; translate: -50% 0;
    display: grid; justify-items: center; gap: 9px; min-width: 46px; padding: 0;
    border: 0; background: transparent; color: var(--secondary);
    font: 11px/1.25 var(--font-data); cursor: pointer; white-space: nowrap;
  }
  .sound-marker[data-lane="middle"] { bottom: 82px; }
  .sound-marker[data-lane="top"] { bottom: 128px; }
  .marker-dot {
    width: 11px; height: 11px; border-radius: 50%; background: var(--secondary);
    box-shadow: 0 0 0 5px var(--surface);
  }
  .sound-marker.warning .marker-dot { background: var(--warning); }
  .sound-marker.danger .marker-dot { background: var(--error); }
  .sound-marker:hover, .sound-marker.active { color: var(--on-surface); }
  .sound-marker.active .marker-dot { box-shadow: 0 0 0 5px var(--surface), 0 0 0 7px currentColor; }
  .sound-marker:focus-visible { outline: 2px solid var(--on-surface); outline-offset: 7px; border-radius: 4px; }
  .sound-detail {
    display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 32px; align-items: end;
    padding: 28px; border: 1px solid var(--ghost); border-radius: var(--radius-card); background: var(--surface-c);
  }
  .detail-category { color: var(--tertiary); font: 10px/1 var(--font-data); letter-spacing: .12em; text-transform: uppercase; }
  .sound-detail h3 { margin: 8px 0; font-size: 24px; }
  .sound-detail p { max-width: 680px; margin: 0; color: var(--on-surface-v); }
  .sound-detail .exposure-note { margin-top: 8px; color: var(--secondary); font-size: 14px; }
  .detail-reading { display: grid; gap: 12px; justify-items: end; }
  .detail-reading strong { font: 600 24px/1 var(--font-data); white-space: nowrap; }
  .detail-reading a { color: var(--on-surface-v); font-size: 14px; text-underline-offset: 4px; }
  .sound-disclaimer { margin: 0; color: var(--tertiary); font-size: 12px; }
  .mobile-sound-view { display: none; }
  .compact .sound-scale { min-height: 230px; }
  @media (max-width: 700px) {
    .sound-scale { margin-inline: -20px; border-radius: 0; border-inline: 0; padding-inline: 20px; }
    .scale-track { left: 20px; right: 20px; }
    .sound-detail { grid-template-columns: 1fr; align-items: start; gap: 20px; padding: 22px; }
    .detail-reading { justify-items: start; }
    .sound-explorer:not(.compact) .sound-scale,
    .sound-explorer:not(.compact) .sound-detail { display: none; }
    .sound-explorer:not(.compact) .mobile-sound-view {
      display: grid; margin-inline: -20px; border-block: 1px solid var(--ghost); background: var(--surface);
    }
    .mobile-scale-key {
      display: flex; justify-content: space-between; padding: 10px 20px 8px;
      color: var(--tertiary); font: 10px/1 var(--font-data); letter-spacing: .08em;
    }
    .mobile-sound-list { display: grid; list-style: none; margin: 0; padding: 0; }
    .mobile-sound-list > li + li { border-top: 1px solid var(--ghost); }
    .mobile-sound-list details[open] { background: var(--surface-c); }
    .mobile-sound-list summary {
      position: relative; display: grid; grid-template-columns: auto minmax(0, 1fr) auto 10px;
      gap: 8px 12px; align-items: center; min-height: 62px; padding: 12px 20px;
      color: var(--on-surface-v); cursor: pointer; list-style: none;
    }
    .mobile-sound-list summary::-webkit-details-marker { display: none; }
    .mobile-sound-list summary:focus-visible { outline: 2px solid var(--on-surface); outline-offset: -4px; }
    .mobile-risk-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--secondary); }
    .mobile-risk-dot.warning { background: var(--warning); }
    .mobile-risk-dot.danger { background: var(--error); }
    .mobile-sound-name { overflow: hidden; color: var(--on-surface); font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }
    .mobile-sound-list summary strong { font: 500 12px/1 var(--font-data); white-space: nowrap; }
    .mobile-disclosure {
      width: 8px; height: 8px; border-right: 1.5px solid currentColor; border-bottom: 1.5px solid currentColor;
      rotate: 45deg; transition: rotate 160ms ease;
    }
    details[open] .mobile-disclosure { rotate: 225deg; }
    .mobile-range-track {
      position: relative; grid-column: 2 / -1; height: 3px; overflow: hidden;
      border-radius: 999px; background: var(--ghost);
    }
    .mobile-range-fill {
      position: absolute; inset-block: 0; left: var(--range-start); width: calc(var(--range-end) - var(--range-start));
      min-width: 5px; border-radius: inherit; background: var(--secondary);
    }
    .mobile-range-fill.warning { background: var(--warning); }
    .mobile-range-fill.danger { background: var(--error); }
    .mobile-sound-detail { display: grid; gap: 8px; padding: 0 20px 16px 42px; }
    .mobile-sound-detail p { margin: 0; color: var(--on-surface-v); font-size: 14px; }
    .mobile-sound-detail .mobile-exposure-note { color: var(--secondary); font-size: 13px; }
    .mobile-sound-detail a { justify-self: start; margin-top: 4px; color: var(--on-surface); font-size: 14px; font-weight: 600; text-underline-offset: 4px; }
  }
</style>
