---
import Base from '../layouts/Base.astro';
import SoundExplorer from './SoundExplorer.astro';
import { getCommonSounds } from '../data/sounds';
import { socialImages } from '../data/social';
import type { Locale } from '../i18n/config';
interface Props { locale: Locale }
const { locale } = Astro.props; const de = locale === 'de'; const sounds = getCommonSounds(locale); const publishedCount = sounds.filter((sound) => sound.articleRoute).length;
---
<Base title={de ? 'Alltagsgeräusche und Dezibelwerte | dBcheck' : 'Common sound levels | dBcheck'} description={de ? 'Vergleichen Sie typische Dezibelbereiche von Alltagsgeräuschen mit Abstand, Messgröße und Kontext.' : 'Explore typical decibel ranges for everyday sounds. Compare common examples and read sourced guides with distance and measurement context.'} socialImage={socialImages.sounds} locale={locale}>
  <section class="sounds-page">
    <header class="page-head"><span class="kicker">{de ? 'Geräuschbibliothek' : 'Sound library'}</span><h1>{de ? 'Alltagsgeräusche auf einer nützlichen Skala.' : 'Common sounds, placed on a useful scale.'}</h1><p>{de ? 'Vergleichen Sie typische Bereiche und öffnen Sie einen quellenbasierten Ratgeber. Die Werte hängen von Abstand, Umgebung und Messmethode ab.' : 'Explore typical ranges, compare examples and open a sourced guide where one is published. These are context-dependent reference ranges, not fixed readings.'}</p></header>
    <SoundExplorer sounds={sounds} id="library-explorer" locale={locale} />
    <div class="library-head"><div><span class="kicker">{de ? 'Erste Sammlung' : 'Initial collection'}</span><h2>{publishedCount} {de ? 'vollständige Ratgeber' : 'complete guides'}, {sounds.length} {de ? 'Vergleiche' : 'comparisons'}</h2></div><p>{de ? 'Geräusche ohne vollständigen Artikel bleiben im Explorer sichtbar, ohne auf unfertige Seiten zu verlinken.' : 'Sounds without a full article remain available in the Explorer without linking to unfinished pages.'}</p></div>
    <ul class="sound-list">{sounds.map((sound) => <li>{sound.articleRoute ? <a class="sound-row" href={sound.articleRoute}><span class="sound-category">{sound.category}</span><strong>{sound.name}</strong><span>{sound.typicalMinDb}–{sound.typicalMaxDb} dB</span><span class="sound-status">{de ? 'Ratgeber lesen' : 'Read guide'} <span aria-hidden="true">→</span></span></a> : <div class="sound-row"><span class="sound-category">{sound.category}</span><strong>{sound.name}</strong><span>{sound.typicalMinDb}–{sound.typicalMaxDb} dB</span><span class="sound-status">{de ? 'Nur Explorer' : 'Explorer only'}</span></div>}</li>)}</ul>
    <aside class="measurement-note"><h2>{de ? 'Zu Smartphone-Messungen' : 'About phone measurements'}</h2><p>{de ? 'Smartphone-Messwerte hängen von Mikrofon, Audioverarbeitung und Kalibrierung ab. dBcheck ist kein zertifizierter Schallpegelmesser der Klasse 1 oder 2. Verwenden Sie diese Bereiche zur Bildung und persönlichen Orientierung, nicht für den Nachweis gesetzlicher Anforderungen.' : 'Smartphone readings depend on the device microphone, audio processing and calibration. dBcheck is not a certified Class 1 or Class 2 sound level meter. Use these ranges and phone readings for education and personal awareness, not regulatory compliance.'}</p></aside>
  </section>
  <style>
    .sounds-page{max-width:var(--max-w);margin:0 auto;padding:64px 20px 0}.page-head{display:grid;gap:16px;max-width:800px;margin-bottom:48px}h1{margin:0;font:700 var(--font-size-page-title)/1.02 var(--font-data);letter-spacing:-.03em}.page-head p{max-width:680px;margin:0;color:var(--on-surface-v);font-size:18px}.library-head{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:end;margin:88px 0 28px}.library-head h2{margin:8px 0 0;font-size:32px}.library-head p{margin:0;color:var(--on-surface-v)}.sound-list{list-style:none;margin:0;padding:0;border-top:1px solid var(--ghost)}.sound-row{display:grid;grid-template-columns:1fr 2fr 1fr 1fr;gap:20px;align-items:center;padding:22px 4px;border-bottom:1px solid var(--ghost);text-decoration:none}a.sound-row:hover{background:var(--surface)}.sound-category,.sound-status{color:var(--secondary);font-size:13px}.sound-status{text-align:right}.measurement-note{display:grid;grid-template-columns:.65fr 1.35fr;gap:40px;margin-top:72px;padding:32px;border:1px solid var(--ghost);border-radius:var(--radius-card);background:var(--surface)}.measurement-note h2,.measurement-note p{margin:0}.measurement-note h2{font-size:22px}.measurement-note p{color:var(--on-surface-v)}@media(max-width:700px){.page-head{margin-bottom:32px}.library-head,.sound-list{display:none}.measurement-note{grid-template-columns:1fr;gap:16px;margin-top:40px}}
  </style>
</Base>
