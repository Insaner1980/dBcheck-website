---
import { socialImages, type SocialImage } from '../data/social';
import { defaultLocale, isLocale, localeTags, openGraphLocales, type Locale } from '../i18n/config';
import { alternatesForPath, findRoutePair, type AlternateLink } from '../i18n/routes';
import { getUi, ui } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>[];
  socialImage?: SocialImage;
  locale?: Locale;
  alternates?: AlternateLink[];
}
const {
  title,
  description = 'dBcheck is an Android sound awareness meter with free educational sound tools and personal relative hearing-result tracking.',
  ogType = 'website',
  jsonLd = [],
  socialImage = socialImages.app,
  locale: localeProp,
  alternates: alternateProp,
} = Astro.props;
const locale = localeProp ?? (isLocale(Astro.currentLocale) ? Astro.currentLocale : defaultLocale);
const copy = getUi(locale);
const canonical = new URL(Astro.url.pathname, Astro.site);
const alternates = alternateProp ?? alternatesForPath(Astro.url.pathname);
const isLocalized = locale !== defaultLocale;
const localizedRoute = (defaultPath: string) => findRoutePair(defaultPath)?.[locale] ?? defaultPath;
const searchIndexUrl = isLocalized ? `/${locale}/search.json` : '/search.json';
const socialImageUrl = new URL(socialImage.src, Astro.site);
const serializeJsonLd = (value: Record<string, unknown>) => JSON.stringify(value).replace(/</g, '\\u003c');
const ga4MeasurementId = 'G-9J90097M6J';
---
<!doctype html>
<html lang={locale}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="generator" content={Astro.generator} />
  <meta name="theme-color" content="#080808" />
  <link rel="canonical" href={canonical} />
  {alternates.map((alternate) => <link rel="alternate" hreflang={localeTags[alternate.locale]} href={new URL(alternate.href, Astro.site)} />)}
  {alternates.some((alternate) => alternate.locale === 'en') && <link rel="alternate" hreflang="x-default" href={new URL(alternates.find((alternate) => alternate.locale === 'en')!.href, Astro.site)} />}
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={socialImageUrl} />
  <meta property="og:image:secure_url" content={socialImageUrl} />
  <meta property="og:image:type" content="image/webp" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={socialImage.alt} />
  <meta property="og:locale" content={openGraphLocales[locale]} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImageUrl} />
  <meta name="twitter:image:alt" content={socialImage.alt} />
  {jsonLd.map((item) => <script type="application/ld+json" set:html={serializeJsonLd(item)} />)}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Instrument+Sans:wght@400..700&display=swap" rel="stylesheet" />
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
  <script define:vars={{ ga4MeasurementId }}>
    window.dataLayer = window.dataLayer || [];
    function gtag() { window.dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', ga4MeasurementId);
  </script>
</head>
<body>
  <a class="skip-link" href="#main">{copy.skip}</a>

  <header class="site-header">
    <nav class="nav" aria-label={copy.mainNav}>
      <a class="wordmark" href="/">
        <svg class="wordmark-eq" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
          <g fill="currentColor">
            <rect x="2"  y="9"  width="2.5" height="6"  rx="1.25"/>
            <rect x="7"  y="5"  width="2.5" height="14" rx="1.25"/>
            <rect x="12" y="2"  width="2.5" height="20" rx="1.25"/>
            <rect x="17" y="7"  width="2.5" height="10" rx="1.25"/>
            <rect x="21.5" y="10" width="2.5" height="4" rx="1.25"/>
          </g>
        </svg>
        <span>dB<em>check</em></span>
      </a>
      <button class="menu-btn" id="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-links">
        <span class="menu-label">{copy.menu}</span>
        <span class="menu-icon" aria-hidden="true"></span>
      </button>
      <div class="nav-links" id="primary-links">
        {isLocalized ? <>
          <a href={localizedRoute('/tools/')}>{copy.tools}</a><a href={localizedRoute('/articles/')}>{copy.articles}</a>
        </> : <>
          <a href="/tools/">Tools</a><a href="/#features">Features</a><a href="/#pricing">Pricing</a><a href="/articles/">Articles</a>
        </>}
      </div>
      <button class="search-btn" id="search-open" aria-label={copy.search} title={`${copy.search} ( / )`}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
      </button>
    </nav>
  </header>

  <dialog class="search-overlay" id="search-overlay" aria-labelledby="search-title" data-search-index={searchIndexUrl} closedby="any" hidden>
    <div class="search-panel">
      <div class="search-head">
        <span class="search-kicker" id="search-title">{copy.searchTitle}</span>
        <button class="search-close" id="search-close" aria-label={copy.closeSearch}>ESC</button>
      </div>
      <label class="search-label" for="search-input">{copy.searchLabel}</label>
      <input id="search-input" type="search" placeholder={copy.searchPlaceholder} autocomplete="off" spellcheck="false" autofocus />
      <div class="search-scale" aria-hidden="true">
        <span>0</span><span>25</span><span>50</span><span>75</span><span>100</span><span>130 dB</span>
      </div>
      <ul id="search-results" class="search-results"></ul>
      <p id="search-empty" class="search-empty" hidden>{copy.searchEmpty}</p>
    </div>
  </dialog>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class:list={['footer-inner', { 'footer-inner--localized': locale === 'de' }]}>
      <div class="footer-brand">
        <span class="wordmark-sm">dB<em>check</em></span>
        <p>{copy.footerTagline.split('\n').map((line, index) => <Fragment>{index > 0 && <br />}{line}</Fragment>)}</p>
      </div>
      <div class="footer-col">
        <span class="footer-label">{copy.footerExplore}</span>
        {locale === 'de' ? <>
          <a href="/de/werkzeuge/">{copy.tools}</a><a href="/de/artikel/">{copy.articles}</a><a href="mailto:contact@finnvek.com">{copy.contact}</a>
        </> : <>
          <a href="/tools/">Tools</a><a href="/#features">Features</a><a href="/#pricing">Pricing</a><a href="/articles/">Articles</a>
        </>}
      </div>
      {locale !== 'de' && (
        <div class="footer-col">
          <span class="footer-label">{ui.en.app}</span>
          <a href="/#get">{ui.en.comingSoon}</a>
          <a href="/#hero">{ui.en.listen}</a>
          <a href="mailto:contact@finnvek.com">{ui.en.contact}</a>
        </div>
      )}
    </div>
    <div class="footer-meta">
      <span class="footer-copyright"><span>© {new Date().getFullYear()} dBcheck</span><a href="https://finnvek.com">Finnvek</a></span>
      <span>{copy.disclaimer}</span>
    </div>
  </footer>

  <script>
    const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Mobile navigation ----
    const menuToggle = document.getElementById('menu-toggle');
    const primaryLinks = document.getElementById('primary-links');
    const setMenuOpen = (open: boolean) => {
      menuToggle?.setAttribute('aria-expanded', String(open));
      primaryLinks?.classList.toggle('open', open);
    };
    menuToggle?.addEventListener('click', () => setMenuOpen(menuToggle.getAttribute('aria-expanded') !== 'true'));
    primaryLinks?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMenuOpen(false)));

    // ---- Shared heading transition ----
    document.addEventListener('click', (event) => {
      const link = (event.target as Element | null)?.closest<HTMLAnchorElement>('a[href^="/"]');
      const card = link?.closest('.article-card, .tool-card');
      const cardHeading = card?.querySelector<HTMLElement>('h2, h3');
      if (!cardHeading) return;
      document.querySelector<HTMLElement>('main h1')?.style.setProperty('view-transition-name', 'none');
      cardHeading.style.setProperty('view-transition-name', 'page-heading');
    });

    // ---- Search overlay ----
    const overlay = document.getElementById('search-overlay') as HTMLDialogElement | null;
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    const resultsEl = document.getElementById('search-results');
    const emptyEl = document.getElementById('search-empty');
    let index: { title: string; description: string; tags: string[]; url: string; kind: string }[] | null = null;
    let searchTrigger: HTMLElement | null = null;

    async function loadIndex() {
      if (index) return index;
      const res = await fetch(overlay?.dataset.searchIndex ?? '/search.json');
      index = await res.json();
      return index;
    }

    function openSearch() {
      if (!overlay || overlay.open) return;
      searchTrigger = document.activeElement as HTMLElement | null;
      overlay.hidden = false;
      overlay.classList.remove('is-closing');
      overlay.showModal();
      document.body.classList.add('search-open');
      loadIndex();
      requestAnimationFrame(() => input?.focus());
    }
    function closeSearch() {
      if (!overlay?.open) return;
      const finish = () => {
        overlay.close();
        overlay.classList.remove('is-closing');
      };
      const panel = overlay.querySelector('.search-panel');
      if (prefersReduced || !panel) {
        finish();
        return;
      }
      overlay.classList.add('is-closing');
      const onAnimationEnd = (event: AnimationEvent) => {
        if (event.target !== panel) return;
        panel.removeEventListener('animationend', onAnimationEnd as EventListener);
        finish();
      };
      panel.addEventListener('animationend', onAnimationEnd as EventListener);
    }

    document.getElementById('search-open')?.addEventListener('click', openSearch);
    document.getElementById('search-close')?.addEventListener('click', closeSearch);
    overlay?.addEventListener('click', (event) => {
      const panel = overlay.querySelector('.search-panel')?.getBoundingClientRect();
      if (!panel) return;
      const outside = event.clientX < panel.left || event.clientX > panel.right || event.clientY < panel.top || event.clientY > panel.bottom;
      if (outside) closeSearch();
    });
    overlay?.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeSearch();
    });
    if (overlay?.open) overlay.close();
    if (overlay) overlay.hidden = true;
    overlay?.addEventListener('close', () => {
      overlay.hidden = true;
      document.body.classList.remove('search-open');
      searchTrigger?.focus();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && !overlay?.open && !(e.target instanceof HTMLInputElement) && !(e.target instanceof HTMLTextAreaElement)) {
        e.preventDefault();
        openSearch();
      }
    });

    // ---- Scroll reveal ----
    const revealSelectors = [
      '.hero-copy', '.hero-hud', '.section-head', '.why-card', '.feature-row',
      '.feature-group-head', '.plan', '.article-card', '.strip-inner',
      '.cta-inner', '.article-list li', '.page-head', '.privacy-note',
      '.sound-explorer', '.exposure-calculator', '.tool-card', '.sound-list li',
    ];
    const revealEls = Array.from(document.querySelectorAll(revealSelectors.join(',')));
    revealEls.forEach((el) => el.classList.add('reveal'));
    if (prefersReduced || !('IntersectionObserver' in window)) {
      revealEls.forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const el = entry.target as HTMLElement;
          const siblings = Array.from(el.parentElement?.children ?? [])
            .filter((c) => c.classList.contains('reveal') && !c.classList.contains('in'));
          const idx = Math.max(0, siblings.indexOf(el));
          el.style.transitionDelay = `${Math.min(idx, 7) * 80}ms`;
          el.classList.add('in');
          io.unobserve(el);
        }
      }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });
      revealEls.forEach((el) => io.observe(el));
    }

    // ---- Live result motion ----
    if (!prefersReduced) {
      const resultFrames = new WeakMap<Element, number>();
      document.querySelectorAll('.calculator-result strong').forEach((output) => {
        const observer = new MutationObserver(() => {
          const result = output.closest('.calculator-result');
          if (!result) return;
          const pendingFrame = resultFrames.get(result);
          if (pendingFrame) cancelAnimationFrame(pendingFrame);
          result.classList.remove('result-updated');
          resultFrames.set(result, requestAnimationFrame(() => {
            result.classList.add('result-updated');
            resultFrames.delete(result);
          }));
        });
        observer.observe(output, { childList: true, characterData: true, subtree: true });
      });
    }

    input?.addEventListener('input', async () => {
      const q = input.value.trim().toLowerCase();
      const data = (await loadIndex()) ?? [];
      if (!resultsEl || !emptyEl) return;
      resultsEl.innerHTML = '';
      if (!q) { emptyEl.hidden = true; return; }
      const hits = data.filter((d) =>
        d.title.toLowerCase().includes(q) ||
        d.description.toLowerCase().includes(q) ||
        d.tags.some((t) => t.toLowerCase().includes(q))
      ).slice(0, 12);
      emptyEl.hidden = hits.length > 0;
      for (const [hitIndex, hit] of hits.entries()) {
        const li = document.createElement('li');
        li.style.setProperty('--hit-index', String(hitIndex));
        const a = document.createElement('a');
        a.href = hit.url;
        const kind = document.createElement('span');
        kind.className = 'hit-kind';
        kind.textContent = hit.kind;
        const title = document.createElement('span');
        title.className = 'hit-title';
        title.textContent = hit.title;
        const desc = document.createElement('span');
        desc.className = 'hit-desc';
        desc.textContent = hit.description;
        a.append(kind, title, desc);
        li.appendChild(a);
        resultsEl.appendChild(li);
      }
    });
  </script>

  <style is:global>
    @view-transition { navigation: auto; }

    :root {
      /* dBcheck dark theme tokens (from app UI spec) */
      --bg: #080808;
      --surface: #101010;
      --surface-c: #171717;
      --surface-ch: #202020;
      --surface-chh: #2A2A2A;
      --on-surface: #F5F5F5;
      --on-surface-v: #B8B8B8;
      --primary: #F7F7F7;
      --primary-dim: #CFCFCF;
      --secondary: #8F8F8F;
      --tertiary: #5E5E5E;
      --outline-v: #8C8C8C;
      --ghost: rgba(140, 140, 140, 0.15);
      --result-border-color: var(--on-surface);
      --error: #E07A7A;
      --warning: #C9A24D;
      --success: #8EA58E;
      --font-body: 'Instrument Sans', system-ui, sans-serif;
      --font-data: 'IBM Plex Mono', ui-monospace, 'SFMono-Regular', Consolas, monospace;
      --font-size-page-title: clamp(2.625rem, 7vw, 4.125rem);
      --radius-card: 24px;
      --radius-tile: 14px;
      --max-w: 1120px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--on-surface);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }
    ::selection { background: var(--on-surface); color: var(--bg); }
    a { color: inherit; }
    :where(a, button, input, summary):focus-visible { outline: 2px solid var(--on-surface); outline-offset: 4px; }
    .skip-link {
      position: absolute; left: -999px; top: 0;
      background: var(--on-surface); color: var(--bg);
      padding: 8px 16px; z-index: 100; border-radius: 0 0 8px 0;
    }
    .skip-link:focus { left: 0; }

    /* Teknisten tunnisteiden ja mittausdatan yhtenäinen typografia. */
    .kicker {
      font-family: var(--font-data);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--secondary);
    }

    /* ---- Motion ---- */
    @keyframes page-exit {
      to { opacity: 0; transform: translateY(-8px); }
    }
    @keyframes page-enter {
      from { opacity: 0; transform: translateY(10px); }
    }
    ::view-transition-old(root) { animation: page-exit 160ms ease-in both; }
    ::view-transition-new(root) { animation: page-enter 280ms cubic-bezier(.2,.7,.2,1) both; }
    ::view-transition-group(page-heading) { animation-duration: 380ms; animation-timing-function: cubic-bezier(.2,.7,.2,1); }
    main h1 { view-transition-name: page-heading; }

    .reveal {
      opacity: 0;
      translate: 0 26px;
      transition: opacity 700ms cubic-bezier(0.2, 0.6, 0.2, 1), translate 700ms cubic-bezier(0.2, 0.6, 0.2, 1);
    }
    .reveal.in { opacity: 1; translate: 0 0; }

    /* live equalizer wordmark — animates on hover and while the hero is measuring */
    .wordmark-eq rect { transform-box: fill-box; transform-origin: center; }
    @keyframes eq-pulse {
      0%, 100% { transform: scaleY(0.45); }
      50% { transform: scaleY(1); }
    }
    .wordmark:hover .wordmark-eq rect,
    body.is-listening .wordmark-eq rect { animation: eq-pulse 1.1s ease-in-out infinite; }
    .wordmark-eq rect:nth-child(1) { animation-delay: 0ms; }
    .wordmark-eq rect:nth-child(2) { animation-delay: 140ms; }
    .wordmark-eq rect:nth-child(3) { animation-delay: 280ms; }
    .wordmark-eq rect:nth-child(4) { animation-delay: 90ms; }
    .wordmark-eq rect:nth-child(5) { animation-delay: 210ms; }

    /* gentle card lift on hover */
    .why-card, .article-card, .plan, .stat-tile {
      transition: translate 250ms ease, background 200ms ease;
    }
    .why-card:hover, .article-card:hover, .plan:hover { translate: 0 -4px; }

    .calculator-result.result-updated strong { animation: result-value-enter 220ms cubic-bezier(.2,.7,.2,1); }
    @keyframes result-value-enter {
      from { opacity: .3; transform: translateY(7px); }
    }

    @media (prefers-reduced-motion: reduce) {
      ::view-transition-group(*), ::view-transition-old(*), ::view-transition-new(*) { animation: none !important; }
      html { scroll-behavior: auto; }
      .reveal { opacity: 1; translate: none; transition: none; }
      .wordmark-eq rect { animation: none !important; }
      .why-card:hover, .article-card:hover, .plan:hover { translate: none; }
      .calculator-result.result-updated strong { animation: none; }
      .search-panel, .search-results li { animation: none !important; }
      body.search-open .search-btn { scale: 1; opacity: 1; }
    }

    /* ---- Header ---- */
    .site-header {
      position: sticky; top: 0; z-index: 50;
      background: rgba(8, 8, 8, 0.82);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--ghost);
    }
    .nav {
      max-width: var(--max-w);
      margin: 0 auto;
      display: flex; align-items: center; gap: 32px;
      padding: 14px 20px;
    }
    .wordmark {
      display: inline-flex; align-items: center; gap: 10px;
      text-decoration: none;
      font-family: var(--font-body);
      font-weight: 600; font-size: 18px; letter-spacing: normal;
    }
    .wordmark em, .wordmark-sm em { font-style: normal; color: var(--secondary); }
    .wordmark-eq { color: var(--primary); }
    .nav-links { display: flex; gap: 24px; margin-left: auto; }
    .nav-links a {
      text-decoration: none;
      font-size: 14px; font-weight: 500;
      color: var(--on-surface-v);
      transition: color 160ms ease;
    }
    .nav-links a:hover { color: var(--on-surface); }
    .menu-btn { display: none !important; }
    .search-btn {
      display: grid; place-items: center;
      width: 40px; height: 40px;
      border-radius: 999px;
      border: 1px solid var(--ghost);
      background: transparent; color: var(--on-surface-v);
      cursor: pointer;
      transition: color 160ms ease, border-color 160ms ease, scale 180ms ease, opacity 180ms ease;
    }
    .search-btn:hover { color: var(--on-surface); border-color: var(--outline-v); }
    body.search-open .search-btn { scale: .86; opacity: .35; }

    /* ---- Search overlay ---- */
    .search-overlay {
      position: fixed; inset: 0; z-index: 90; width: 100%; max-width: none; height: 100%; max-height: none; margin: 0;
      border: 0;
      background: rgba(8, 8, 8, 0.72);
      backdrop-filter: blur(8px);
      display: flex; justify-content: center;
      padding: 12vh 20px 40px;
      color: var(--on-surface);
    }
    .search-overlay[hidden] { display: none !important; }
    .search-overlay:not([open]) { display: none; }
    .search-overlay::backdrop { background: transparent; }
    .search-panel {
      width: 100%; max-width: 640px; height: fit-content;
      background: var(--surface-c);
      border: 1px solid var(--ghost);
      border-radius: var(--radius-card);
      padding: 24px;
      transform-origin: calc(100% - 24px) 0;
      animation: search-panel-enter 280ms cubic-bezier(.16,.8,.2,1) both;
    }
    .search-overlay.is-closing .search-panel { animation: search-panel-exit 160ms ease-in both; }
    @keyframes search-panel-enter {
      from { opacity: 0; transform: translate(18px, -18px) scale(.82); }
    }
    @keyframes search-panel-exit {
      to { opacity: 0; transform: translate(18px, -18px) scale(.9); }
    }
    .search-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .search-kicker { font-family: var(--font-data); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--secondary); }
    .search-label { display: block; margin-bottom: 8px; color: var(--on-surface-v); font-size: 13px; font-weight: 600; }
    .search-close {
      font-family: var(--font-data); font-size: 11px; letter-spacing: 0.08em;
      background: var(--surface-chh); color: var(--on-surface-v);
      border: none; border-radius: 6px; padding: 6px 10px; cursor: pointer;
    }
    #search-input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--ghost);
      border-radius: 12px;
      color: var(--on-surface);
      font-family: var(--font-body); font-size: 18px;
      padding: 14px 16px;
      outline: none;
    }
    #search-input:focus { border-color: rgba(247, 247, 247, 0.3); }
    #search-input::-webkit-search-cancel-button {
      appearance: none;
      width: 18px;
      height: 18px;
      cursor: pointer;
      background:
        linear-gradient(45deg, transparent 45%, var(--on-surface-v) 46% 54%, transparent 55%),
        linear-gradient(-45deg, transparent 45%, var(--on-surface-v) 46% 54%, transparent 55%);
    }
    #search-input:hover::-webkit-search-cancel-button {
      background:
        linear-gradient(45deg, transparent 45%, var(--on-surface) 46% 54%, transparent 55%),
        linear-gradient(-45deg, transparent 45%, var(--on-surface) 46% 54%, transparent 55%);
    }
    .search-scale {
      display: flex; justify-content: space-between;
      margin: 10px 4px 6px;
      font-family: var(--font-data); font-size: 10px; letter-spacing: 0.08em;
      color: var(--tertiary);
    }
    .search-results {
      list-style: none; margin: 8px 0 0; padding: 0; max-height: 44vh; overflow-y: auto;
      scrollbar-color: var(--secondary) var(--surface);
      scrollbar-width: thin;
    }
    .search-results::-webkit-scrollbar { width: 10px; }
    .search-results::-webkit-scrollbar-track { background: var(--surface); border-radius: 999px; }
    .search-results::-webkit-scrollbar-thumb {
      background: var(--secondary);
      border: 3px solid var(--surface);
      border-radius: 999px;
    }
    .search-results::-webkit-scrollbar-thumb:hover { background: var(--on-surface-v); }
    .search-results a {
      display: grid; gap: 2px;
      padding: 12px 14px; border-radius: var(--radius-tile);
      text-decoration: none;
    }
    .search-results a:hover { background: var(--surface-ch); }
    .search-results li { animation: search-hit-enter 220ms cubic-bezier(.2,.7,.2,1) both; animation-delay: calc(var(--hit-index) * 35ms); }
    @keyframes search-hit-enter { from { opacity: 0; transform: translateY(6px); } }
    .hit-kind { font-family: var(--font-data); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--tertiary); }
    .hit-title { font-weight: 600; }
    .hit-desc { font-size: 13px; color: var(--on-surface-v); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .search-empty { color: var(--secondary); font-size: 14px; padding: 16px 4px 4px; margin: 0; }

    /* ---- Footer ---- */
    .site-footer { border-top: 1px solid var(--ghost); margin-top: 96px; }
    .footer-inner {
      max-width: var(--max-w); margin: 0 auto;
      display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 32px;
      padding: 48px 20px 32px;
    }
    .footer-inner--localized { grid-template-columns: 2fr 1fr; }
    .wordmark-sm { font-family: var(--font-body); font-weight: 600; font-size: 16px; }
    .footer-brand p { color: var(--secondary); font-size: 14px; margin: 12px 0 0; max-width: 320px; }
    .footer-col { display: grid; gap: 10px; align-content: start; }
    .footer-label { font-family: var(--font-data); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--tertiary); }
    .footer-col a { color: var(--on-surface-v); text-decoration: none; font-size: 14px; }
    .footer-col a:hover { color: var(--on-surface); }
    .footer-meta {
      max-width: var(--max-w); margin: 0 auto;
      display: flex; flex-wrap: wrap; gap: 8px 24px; justify-content: space-between;
      padding: 0 20px 32px;
      color: var(--tertiary); font-size: 12px;
    }
    .footer-meta a { color: inherit; text-underline-offset: 3px; }
    .footer-meta a:hover { color: var(--secondary); }
    .footer-copyright { display: grid; gap: 2px; }
    @media (max-width: 900px) {
      .nav { position: relative; gap: 12px; }
      .menu-btn {
        display: inline-flex !important; align-items: center; gap: 8px; margin-left: auto;
        min-height: 40px; padding: 0 12px; border: 1px solid var(--ghost); border-radius: 999px;
        background: transparent; color: var(--on-surface-v); font: 500 13px/1 var(--font-body); cursor: pointer;
      }
      .menu-icon { position: relative; width: 14px; height: 10px; border-block: 1px solid currentColor; }
      .menu-icon::after { content: ''; position: absolute; left: 0; right: 0; top: 4px; border-top: 1px solid currentColor; }
      .nav-links {
        display: none; position: absolute; top: 100%; left: 12px; right: 12px;
        grid-template-columns: 1fr 1fr; gap: 0; margin: 0; padding: 10px;
        border: 1px solid var(--ghost); border-radius: 0 0 var(--radius-tile) var(--radius-tile);
        background: rgba(8,8,8,.98); box-shadow: 0 20px 40px rgba(0,0,0,.35);
      }
      .nav-links.open { display: grid; }
      .nav-links a { padding: 13px 12px; border-radius: 8px; }
      .nav-links a:hover { background: var(--surface-ch); }
      .footer-inner { grid-template-columns: 1fr; }
    }
    @media (max-width: 520px) {
      .menu-label { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
      .menu-btn { width: 40px; justify-content: center; padding: 0; }
      .nav-links { grid-template-columns: 1fr; }
      .search-panel { padding: 20px; }
    }
  </style>
</body>
</html>
